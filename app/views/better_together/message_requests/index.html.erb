<% content_for :page_title do %>
  <%= t('.title') %>
<% end %>

<div class="container my-3">
  <h1><%= t('.title') %></h1>

  <% if @message_requests.any? %>
    <div class="list-group">
      <% @message_requests.each do |req| %>
        <div class="list-group-item list-group-item-action">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="mb-1">
                <strong><%= req.sender.name %></strong>
                <%= t('.wants_to_message_you') %>
              </p>
              <blockquote class="blockquote fs-6 text-muted mb-2">
                <%= req.note %>
              </blockquote>
              <small class="text-muted"><%= time_ago_in_words(req.created_at) %> <%= t('.ago') %></small>
            </div>
            <div class="btn-group btn-group-sm ms-3">
              <%= button_to t('.accept_btn'),
                            accept_message_request_path(req),
                            method: :put,
                            class: 'btn btn-success btn-sm',
                            data: { turbo_confirm: t('.accept_confirm') } %>
              <%= button_to t('.decline_btn'),
                            decline_message_request_path(req),
                            method: :put,
                            class: 'btn btn-outline-secondary btn-sm' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <%= t('.none_pending') %>
    </div>
  <% end %>
</div>
