<tr id="<%= dom_id platform %>" class="<%= dom_class platform %>">
  <td><%= platform.identifier %></td>
  <td><%= platform.name %></td>
  <td><%= platform.description %></td>
  <td><%= platform.slug %></td>
  <td><%= link_to sanitize_url(platform.host_url), sanitize_url(platform.host_url), target: "_blank", rel: "noopener noreferrer" %></td>
  <td><%= platform.time_zone %></td>
  <td><%= privacy_display_value(platform) %></td>
  <td><%= platform.protected ? t('globals.yes') : t('globals.no') %></td>
  <td><%= platform.host ? t('globals.yes') : t('globals.no') %></td>
  <td class="text-end">
    <% if policy(platform).show? %>
      <%= link_to platform_path(platform), class: 'btn btn-outline-info btn-sm me-1', 'aria-label' => t('platforms.show.actions.show_aria') do %>
        <i class="fas fa-eye" aria-hidden="true"></i> <%= t('globals.show') %>
      <% end %>
    <% end %>
    <% if policy(platform).edit? %>
      <%= link_to edit_platform_path(platform), class: 'btn btn-outline-secondary btn-sm me-1', 'aria-label' => t('platforms.show.actions.edit_aria') do %>
        <i class="fas fa-edit" aria-hidden="true"></i> <%= t('globals.edit') %>
      <% end %>
    <% end %>
    <% if policy(platform).destroy? %>
      <%= link_to platform_path(platform), method: :delete, data: { turbo_method: 'delete', turbo_confirm: t('platforms.confirm_delete') }, class: 'btn btn-outline-danger btn-sm', 'aria-label' => t('platforms.show.actions.destroy_aria') do %>
        <i class="fas fa-trash-alt" aria-hidden="true"></i> <%= t('globals.delete') %>
      <% end %>
    <% end %>
  </td>
</tr>
