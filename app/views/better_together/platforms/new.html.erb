<%= render layout: 'layouts/better_together/host_nav' do %>
  <% content_for :page_title do %>
    Register External Platform
  <% end %>

  <div class="container my-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1>Register External Platform</h1>
      <%= link_to 'Back', better_together.platforms_path, class: 'btn btn-outline-secondary' %>
    </div>

    <p class="text-muted mb-4">
      Register a remote Community Engine (or compatible) instance so it can be selected
      when creating a Platform Connection.
    </p>

    <div id="form_errors"></div>

    <%= form_with(model: @platform, url: better_together.platforms_path) do |form| %>
      <%= form.hidden_field :external, value: true %>

      <div class="mb-3">
        <%= render partial: 'better_together/shared/translated_string_field',
                   locals: { model: @platform, form: form, attribute: 'name' } %>
      </div>

      <div class="mb-3">
        <%= form.label :identifier, class: 'form-label' %>
        <%= form.text_field :identifier, class: 'form-control', placeholder: 'e.g. peer-platform' %>
        <div class="form-text">A unique slug identifier for this platform (letters, numbers, hyphens).</div>
      </div>

      <div class="mb-3">
        <%= form.label :host_url, 'URL', class: 'form-label' %>
        <%= form.url_field :host_url, class: 'form-control', placeholder: 'https://example.com' %>
        <div class="form-text">The root URL of the external platform instance.</div>
      </div>

      <div class="mb-3">
        <%= form.label :time_zone, class: 'form-label' %>
        <%= iana_time_zone_select(form, :time_zone, @platform.time_zone, {}, { class: 'form-select', required: true }) %>
      </div>

      <div class="mb-3">
        <%= form.submit 'Register External Platform', class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
<% end %>
