<%= render layout: 'layouts/better_together/host_nav' do %>
  <% content_for :page_title do %>
    <%= t('better_together.platforms.new.title') %>
  <% end %>

  <div class="container my-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1><%= t('better_together.platforms.new.title') %></h1>
      <%= link_to t('better_together.platforms.new.back'), better_together.platforms_path, class: 'btn btn-outline-secondary' %>
    </div>

    <p class="text-muted mb-4">
      <%= t('better_together.platforms.new.intro') %>
    </p>

    <div id="form_errors"></div>

    <%= form_with(model: @platform, url: better_together.platforms_path) do |form| %>
      <%= form.hidden_field :external, value: true %>

      <div class="mb-3">
        <%= render partial: 'better_together/shared/translated_string_field',
                   locals: { model: @platform, form: form, attribute: 'name' } %>
      </div>

      <div class="mb-3">
        <%= form.label :identifier, class: 'form-label' %>
        <%= form.text_field :identifier, class: 'form-control', placeholder: t('better_together.platforms.new.identifier_placeholder') %>
        <div class="form-text"><%= t('better_together.platforms.new.identifier_hint') %></div>
      </div>

      <div class="mb-3">
        <%= form.label :host_url, t('better_together.platforms.new.host_url_label'), class: 'form-label' %>
        <%= form.url_field :host_url, class: 'form-control', placeholder: t('better_together.platforms.new.host_url_placeholder') %>
        <div class="form-text"><%= t('better_together.platforms.new.host_url_hint') %></div>
      </div>

      <div class="mb-3">
        <%= form.label :time_zone, class: 'form-label' %>
        <%= iana_time_zone_select(form, :time_zone, @platform.time_zone, {}, { class: 'form-select', required: true }) %>
      </div>

      <div class="mb-3">
        <%= form.submit t('better_together.platforms.new.submit'), class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
<% end %>
