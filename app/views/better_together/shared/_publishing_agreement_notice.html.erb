<%# locals: () -%>
<% publishing_agreement = BetterTogether::ChecksRequiredAgreements.public_publishing_agreement %>
<% if publishing_agreement.present? && BetterTogether::ChecksRequiredAgreements.missing_public_publishing_agreement?(current_person) %>
  <div class="alert alert-info d-flex align-items-start gap-2 mb-3" role="alert">
    <i class="fas fa-file-signature mt-1" aria-hidden="true"></i>
    <div>
      <p class="mb-2"><%= t('.message') %></p>
      <%= link_to t('.accept_link'),
                  better_together.agreement_path(publishing_agreement, locale: I18n.locale),
                  class: 'btn btn-sm btn-outline-info agreement-modal-link',
                  role: 'button',
                  data: {
                    agreement_identifier: publishing_agreement.identifier,
                    agreement_mode: 'direct_accept',
                    agreement_accept_url: better_together.accept_agreement_path(publishing_agreement, locale: I18n.locale)
                  } %>
    </div>
  </div>
<% end %>
