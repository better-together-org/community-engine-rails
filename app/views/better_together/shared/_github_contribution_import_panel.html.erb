<%# locals: (record:) %>
<% signed_in_user = begin current_user rescue StandardError nil end %>
<% github_import_url = signed_in_user.present? ? better_together.github_citation_imports_path(locale: I18n.locale, format: :json) : nil %>
<% contribution_import_url = if signed_in_user.present? && record.persisted? && record.respond_to?(:citation_export_key)
  better_together.github_contribution_imports_path(contributable_key: record.citation_export_key, id: record.to_param, locale: I18n.locale, format: :json)
end %>

<div class="mt-3"
     data-controller="better_together--github-contribution-import"
     data-better_together--github-contribution-import-github-url-value="<%= github_import_url %>"
     data-better_together--github-contribution-import-import-url-value="<%= contribution_import_url %>"
     data-better_together--github-contribution-import-contributor-id-value="<%= signed_in_user&.person&.id %>">
  <% if record.persisted? && github_import_url.present? && contribution_import_url.present? %>
    <details class="mt-2" data-action="toggle->better_together--github-contribution-import#loadGithubSources">
      <summary class="small fw-semibold">Import GitHub Contribution</summary>
      <div class="mt-3">
        <p class="text-muted small">
          Import linked GitHub activity directly into governed contribution records so code and documentation work can be attributed without manual bridge records.
        </p>
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <button type="button"
                  class="btn btn-sm btn-outline-dark"
                  data-action="click->better_together--github-contribution-import#loadGithubSources"
                  data-better_together--github-contribution-import-target="loadButton">
            Load GitHub Contribution Sources
          </button>
          <span class="small text-muted" data-better_together--github-contribution-import-target="status"></span>
        </div>
        <div class="d-grid gap-3" data-better_together--github-contribution-import-target="groups"></div>
      </div>
    </details>
  <% elsif !record.persisted? %>
    <p class="text-muted small mb-0">Save this record first to import GitHub contribution activity.</p>
  <% end %>
</div>
