<%# locals: (authors:, flex_layout: 'flex-row', flex_align_items: 'center') %>
<% return unless authors.present? %>

<div class="authors-list">
  <span class="visually-hidden"><%= t('better_together.posts.authors', default: 'Authors') %></span>
  <div class="d-flex flex-wrap align-items-center">
    <% authors.each do |author| %>
      <% partial = author.is_a?(BetterTogether::Robot) ? 'better_together/robots/mention' : 'better_together/people/mention' %>
      <% as = author.is_a?(BetterTogether::Robot) ? :robot : :person %>
      <%= render partial:, locals: { as => author, flex_layout: (defined?(flex_layout) ? flex_layout : 'flex-row'), flex_align_items: (defined?(flex_align_items) ? flex_align_items : 'center') } %>
    <% end %>
  </div>
</div>
