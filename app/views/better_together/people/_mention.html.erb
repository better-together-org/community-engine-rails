
<%# locals: (person:, flex_layout: 'flex-row', flex_align_items: 'left', linked: true)%>
<% profile_path = linked ? mention_profile_path(person) : nil %>

<div class="position-relative mention py-2 me-2 d-flex justify-content-center row-gap-1 <%= flex_layout %> <%= "align-items-#{flex_align_items}" %> <%= dom_class(person, :mention) %> <%= 'me' if person == safe_current_person %>" id="<%= dom_id(person, :mention) %>">
  <%# Display avatar and name inline %>
  <div class="h-50">
    <%= profile_image_tag(person, class: 'mention', size: 50) %>
  </div>
  <div class="h-50 align-self-top">
    <% if profile_path %>
      <a class="text-decoration-none identity-name stretched-link" href="<%= profile_path %>">
        <%= person.name %>
      </a>
    <% else %>
      <span class="identity-name"><%= person.name %></span>
    <% end %>
  </div>
</div>