<%= turbo_frame_tag 'my-data-settings' do %>
  <div class="container my-3">
    <% unless turbo_frame_request? %>
      <h1 class="h2 mb-3">
        <i class="fa-solid fa-database me-2" aria-hidden="true"></i>
        <%= t('better_together.settings.index.my_data.title') %>
      </h1>
      <p class="text-muted mb-4"><%= t('better_together.settings.index.my_data.description') %></p>
    <% end %>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h3 class="h5 mb-1"><%= t('better_together.settings.index.my_data.exports.title') %></h3>
            <p class="text-muted mb-0"><%= t('better_together.settings.index.my_data.exports.description') %></p>
          </div>
          <%= button_to person_data_exports_path(locale: locale), method: :post, class: 'btn btn-primary', data: { turbo_submits_with: t('better_together.settings.index.my_data.exports.requesting') } do %>
            <i class="fa-solid fa-download me-1" aria-hidden="true"></i>
            <%= t('better_together.settings.index.my_data.exports.request') %>
          <% end %>
        </div>

        <% if @person_data_exports.empty? %>
          <div class="alert alert-info mb-0" role="status"><%= t('better_together.settings.index.my_data.exports.empty') %></div>
        <% else %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th><%= t('better_together.settings.index.my_data.exports.requested_at') %></th>
                  <th><%= t('better_together.settings.index.my_data.exports.status') %></th>
                  <th><%= t('better_together.settings.index.my_data.exports.actions') %></th>
                </tr>
              </thead>
              <tbody>
                <% @person_data_exports.each do |export| %>
                  <tr id="person_data_export_<%= export.id %>">
                    <td><%= l(export.requested_at, format: :long) %></td>
                    <td><span class="badge text-bg-secondary"><%= export.status.humanize %></span></td>
                    <td>
                      <% if export.completed? && export.export_file.attached? %>
                        <%= link_to t('better_together.settings.index.my_data.exports.download'), person_data_export_path(export, locale: locale), class: 'btn btn-sm btn-outline-primary' %>
                      <% elsif export.failed? %>
                        <span class="text-danger small"><%= export.error_message %></span>
                      <% else %>
                        <span class="text-muted small"><%= t('better_together.settings.index.my_data.exports.pending') %></span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <% if @show_person_links || @show_person_access_grants || @show_person_linked_seeds || @show_person_seeds %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
          <div class="mb-3">
            <h3 class="h5 mb-1"><%= t('better_together.settings.index.my_data.connections.title') %></h3>
            <p class="text-muted mb-0"><%= t('better_together.settings.index.my_data.connections.description') %></p>
          </div>

          <div class="row row-cols-1 row-cols-lg-2 g-3">
            <% if @show_person_links %>
              <div class="col">
                <div class="card h-100 border-0 bg-body-tertiary">
                  <div class="card-body d-flex flex-column">
                    <h4 class="h6"><%= t('better_together.settings.index.my_data.connections.cards.person_links.title') %></h4>
                    <p class="text-muted small flex-grow-1 mb-3"><%= t('better_together.settings.index.my_data.connections.cards.person_links.description') %></p>
                    <%= link_to t('better_together.settings.index.my_data.connections.open_link'),
                                person_links_path(locale: locale),
                                class: 'btn btn-outline-primary btn-sm align-self-start',
                                data: { turbo_frame: '_top' } %>
                  </div>
                </div>
              </div>
            <% end %>

            <% if @show_person_access_grants %>
              <div class="col">
                <div class="card h-100 border-0 bg-body-tertiary">
                  <div class="card-body d-flex flex-column">
                    <h4 class="h6"><%= t('better_together.settings.index.my_data.connections.cards.access_grants.title') %></h4>
                    <p class="text-muted small flex-grow-1 mb-3"><%= t('better_together.settings.index.my_data.connections.cards.access_grants.description') %></p>
                    <%= link_to t('better_together.settings.index.my_data.connections.open_link'),
                                person_access_grants_path(locale: locale),
                                class: 'btn btn-outline-primary btn-sm align-self-start',
                                data: { turbo_frame: '_top' } %>
                  </div>
                </div>
              </div>
            <% end %>

            <% if @show_person_linked_seeds %>
              <div class="col">
                <div class="card h-100 border-0 bg-body-tertiary">
                  <div class="card-body d-flex flex-column">
                    <h4 class="h6"><%= t('better_together.settings.index.my_data.connections.cards.linked_seeds.title') %></h4>
                    <p class="text-muted small flex-grow-1 mb-3"><%= t('better_together.settings.index.my_data.connections.cards.linked_seeds.description') %></p>
                    <%= link_to t('better_together.settings.index.my_data.connections.open_link'),
                                person_linked_seeds_path(locale: locale),
                                class: 'btn btn-outline-primary btn-sm align-self-start',
                                data: { turbo_frame: '_top' } %>
                  </div>
                </div>
              </div>
            <% end %>

            <% if @show_person_seeds %>
              <div class="col">
                <div class="card h-100 border-0 bg-body-tertiary">
                  <div class="card-body d-flex flex-column">
                    <h4 class="h6"><%= t('better_together.settings.index.my_data.connections.cards.person_seeds.title') %></h4>
                    <p class="text-muted small flex-grow-1 mb-3"><%= t('better_together.settings.index.my_data.connections.cards.person_seeds.description') %></p>
                    <%= link_to t('better_together.settings.index.my_data.connections.open_link'),
                                person_seeds_path(locale: locale),
                                class: 'btn btn-outline-primary btn-sm align-self-start',
                                data: { turbo_frame: '_top' } %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

  </div>
<% end %>
