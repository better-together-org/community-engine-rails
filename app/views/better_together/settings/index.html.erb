<!-- filepath: /home/rob/projects/better-together/community-engine-rails/app/views/better_together/settings/index.html.erb -->
<% content_for :page_title, t('.title') %>

<div class="container-fluid mt-4" data-controller="better_together--tabs better_together--integration-notifications">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
          <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>
          <%= t('.title') %>
        </h1>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Vertical Pills Navigation -->
    <div class="col-md-3 mb-3">
      <div class="nav flex-column nav-pills" id="settings-tabs" role="tablist" aria-orientation="vertical">
        <!-- <button class="nav-link" id="platform-tab" data-bs-toggle="pill" data-bs-target="#platform" type="button" role="tab" aria-controls="platform" aria-selected="true" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-server me-2" aria-hidden="true"></i>
          <%= t('.tabs.platform') %>
        </button> -->
        <!-- <button class="nav-link" id="personal-tab" data-bs-toggle="pill" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-user me-2" aria-hidden="true"></i>
          <%= t('.tabs.personal') %>
        </button> -->
        <button class="nav-link text-start active" id="account-tab" data-bs-toggle="pill" data-bs-target="#account" type="button" role="tab" aria-controls="account" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-key me-2" aria-hidden="true"></i>
          <%= t('.tabs.account') %>
        </button>
        <button class="nav-link text-start" id="blocked-people-tab" data-bs-toggle="pill" data-bs-target="#blocked-people" type="button" role="tab" aria-controls="blocked-people" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-user-slash me-2" aria-hidden="true"></i>
          <%= t('.tabs.blocked_people') %>
        </button>
        <button class="nav-link text-start" id="integrations-tab" data-bs-toggle="pill" data-bs-target="#integrations" type="button" role="tab" aria-controls="integrations" aria-selected="false" data-better_together--tabs-target="tab" data-action="shown.bs.tab->better_together--integration-notifications#showTab">
          <i class="fa-brands fa-github me-2" aria-hidden="true"></i>
          <%= t('.tabs.integrations') %>
        </button>
        <button class="nav-link text-start" id="developer-tab" data-bs-toggle="pill" data-bs-target="#developer" type="button" role="tab" aria-controls="developer" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-code me-2" aria-hidden="true"></i>
          <%= t('.tabs.developer') %>
        </button>
        <button class="nav-link text-start" id="device-permissions-tab" data-bs-toggle="pill" data-bs-target="#device-permissions" type="button" role="tab" aria-controls="device-permissions" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-mobile-screen me-2" aria-hidden="true"></i>
          <%= t('.tabs.device_permissions') %>
        </button>
        <button class="nav-link text-start" id="preferences-tab" data-bs-toggle="pill" data-bs-target="#preferences" type="button" role="tab" aria-controls="preferences" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-sliders me-2" aria-hidden="true"></i>
          <%= t('.tabs.preferences') %>
        </button>
        <!-- <button class="nav-link" id="privacy-tab" data-bs-toggle="pill" data-bs-target="#privacy" type="button" role="tab" aria-controls="privacy" aria-selected="false" data-better_together--tabs-target="tab">
          <i class="fa-solid fa-shield-alt me-2" aria-hidden="true"></i>
          <%= t('.tabs.privacy') %>
        </button> -->
      </div>
    </div>

    <!-- Tab Content -->
    <div class="col-md-9 tab-content" id="settings-tabs-content">
      <!-- Platform Tab -->
      <div class="nav-tab-pane tab-pane fade" id="platform" role="tabpanel" aria-labelledby="platform-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-server me-2" aria-hidden="true"></i>
              <%= t('.platform.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.platform.description') %></p>

            <!-- Platform settings content will go here -->
            <div class="alert alert-info" role="status">
              <i class="fa-solid fa-info-circle me-2" aria-hidden="true"></i>
              <%= t('.platform.coming_soon') %>
            </div>
          </div>
        </div>
      </div>

      <!-- Personal Tab -->
      <div class="nav-tab-pane tab-pane fade" id="personal" role="tabpanel" aria-labelledby="personal-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-user me-2" aria-hidden="true"></i>
              <%= t('.personal.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.personal.description') %></p>

            <!-- Personal settings content will go here -->
            <div class="alert alert-info" role="status">
              <i class="fa-solid fa-info-circle me-2" aria-hidden="true"></i>
              <%= t('.personal.coming_soon') %>
            </div>
          </div>
        </div>
      </div>

      <!-- Account Tab -->
      <div class="nav-tab-pane tab-pane fade show active" id="account" role="tabpanel" aria-labelledby="account-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-key me-2" aria-hidden="true"></i>
              <%= t('.account.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.account.description') %></p>

            <!-- Account settings content -->
            <%= turbo_frame_tag "account-settings",
                                src: edit_user_registration_path,
                                loading: "lazy",
                                class: "d-block" do %>
              <div class="d-flex justify-content-center py-4">
                <div class="spinner-border text-primary" role="status">
                  <span class="visually-hidden">Loading...</span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Blocked People Tab -->
      <div class="nav-tab-pane tab-pane fade" id="blocked-people" role="tabpanel" aria-labelledby="blocked-people-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-user-slash me-2" aria-hidden="true"></i>
              <%= t('.blocked_people.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.blocked_people.description') %></p>

            <!-- Blocked people content -->
            <%= turbo_frame_tag "blocked-people-settings",
                                src: person_blocks_path(locale: locale),
                                loading: "lazy",
                                class: "d-block" do %>
              <div class="d-flex justify-content-center py-4">
                <div class="spinner-border text-primary" role="status">
                  <span class="visually-hidden">Loading...</span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Integrations Tab -->
      <div class="nav-tab-pane tab-pane fade" id="integrations" role="tabpanel" aria-labelledby="integrations-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-brands fa-github me-2" aria-hidden="true"></i>
              <%= t('.integrations.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.integrations.description') %></p>

            <!-- Integrations content -->
            <%= turbo_frame_tag "integrations-settings",
                                src: person_platform_integrations_path(locale: locale),
                                loading: "lazy",
                                class: "d-block" do %>
              <div class="d-flex justify-content-center py-4">
                <div class="spinner-border text-primary" role="status">
                  <span class="visually-hidden">Loading...</span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Device Permissions Tab -->
      <div class="nav-tab-pane tab-pane fade" 
           id="device-permissions" 
           role="tabpanel" 
           aria-labelledby="device-permissions-tab"
           data-controller="better_together--device-permissions"
           <%= device_permissions_data_attrs.map { |k, v| "#{k}=\"#{html_escape(v)}\"" }.join(' ').html_safe %>>
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-mobile-screen me-2" aria-hidden="true"></i>
              <%= t('.device_permissions.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.device_permissions.description') %></p>

            <!-- Device permissions content -->
            <%= render 'better_together/people/device_permissions' %>
          </div>
        </div>
      </div>

      <!-- Preferences Tab -->
      <div class="nav-tab-pane tab-pane fade" id="preferences" role="tabpanel" aria-labelledby="preferences-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-sliders me-2" aria-hidden="true"></i>
              <%= t('.preferences.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.preferences.description') %></p>

            <!-- Self-contained preference fields -->
            <%= render 'better_together/people/preferences_self_contained', person: current_user.person %>
          </div>
        </div>
      </div>

      <!-- Privacy Tab -->
      <div class="nav-tab-pane tab-pane fade" id="privacy" role="tabpanel" aria-labelledby="privacy-tab">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h3 class="card-title h5">
              <i class="fa-solid fa-shield-alt me-2" aria-hidden="true"></i>
              <%= t('.privacy.title') %>
            </h3>
            <p class="text-muted mb-4"><%= t('.privacy.description') %></p>

            <!-- Privacy settings content will go here -->
            <div class="alert alert-info" role="status">
              <i class="fa-solid fa-info-circle me-2" aria-hidden="true"></i>
              <%= t('.privacy.coming_soon') %>
            </div>
          </div>
        </div>
      </div>

      <!-- Developer Tab -->
      <div class="nav-tab-pane tab-pane fade" id="developer" role="tabpanel" aria-labelledby="developer-tab">
        <!-- Personal OAuth Applications -->
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title h5 mb-0">
              <i class="fa-solid fa-plug me-2" aria-hidden="true"></i>
              <%= t('.developer.apps.title') %>
            </h3>
            <%= link_to new_personal_oauth_application_path(locale: locale),
                        class: 'btn btn-sm btn-primary',
                        'aria-label' => t('.developer.apps.new_aria') do %>
              <i class="fa-solid fa-plus me-1" aria-hidden="true"></i>
              <%= t('.developer.apps.new_btn') %>
            <% end %>
          </div>
          <div class="card-body">
            <p class="text-muted small mb-3"><%= t('.developer.apps.description') %></p>
            <% if @person_oauth_apps.any? %>
              <div class="list-group list-group-flush">
                <% @person_oauth_apps.each do |app| %>
                  <div class="list-group-item px-0">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <strong><%= app.name %></strong>
                        <% if app.scopes.present? %>
                          <div class="mt-1">
                            <% app.scopes.to_a.each do |scope| %>
                              <span class="badge bg-light text-dark border me-1"><%= scope %></span>
                            <% end %>
                          </div>
                        <% end %>
                        <div class="text-muted small mt-1">
                          <%= t('.developer.apps.client_id_label') %>:
                          <code class="small"><%= app.uid.truncate(20) %></code>
                        </div>
                      </div>
                      <div class="btn-group btn-group-sm">
                        <%= link_to personal_oauth_application_path(app, locale: locale),
                                    class: 'btn btn-outline-secondary btn-sm',
                                    'aria-label' => t('.developer.apps.view_aria', name: app.name) do %>
                          <i class="fa-solid fa-eye" aria-hidden="true"></i>
                        <% end %>
                        <%= link_to edit_personal_oauth_application_path(app, locale: locale),
                                    class: 'btn btn-outline-secondary btn-sm',
                                    'aria-label' => t('.developer.apps.edit_aria', name: app.name) do %>
                          <i class="fa-solid fa-pen" aria-hidden="true"></i>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0"><%= t('.developer.apps.none') %></p>
            <% end %>
          </div>
        </div>

        <!-- Active Access Tokens -->
        <div class="card border-0 shadow-sm">
          <div class="card-header">
            <h3 class="card-title h5 mb-0">
              <i class="fa-solid fa-key me-2" aria-hidden="true"></i>
              <%= t('.developer.tokens.title') %>
            </h3>
          </div>
          <div class="card-body">
            <p class="text-muted small mb-3"><%= t('.developer.tokens.description') %></p>
            <% if @access_tokens.any? %>
              <div class="table-responsive">
                <table class="table table-sm" aria-label="<%= t('.developer.tokens.table_aria') %>">
                  <thead class="table-light">
                    <tr>
                      <th scope="col"><%= t('.developer.tokens.col_app') %></th>
                      <th scope="col"><%= t('.developer.tokens.col_scopes') %></th>
                      <th scope="col"><%= t('.developer.tokens.col_created') %></th>
                      <th scope="col"><%= t('.developer.tokens.col_expires') %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @access_tokens.each do |token| %>
                      <tr>
                        <td><%= token.application&.name || t('.developer.tokens.no_app') %></td>
                        <td>
                          <% token.scopes.to_a.each do |scope| %>
                            <span class="badge bg-light text-dark border me-1 small"><%= scope %></span>
                          <% end %>
                        </td>
                        <td class="small text-muted"><%= l(token.created_at, format: :short) %></td>
                        <td class="small text-muted">
                          <% if token.expires_in.present? %>
                            <%= l(token.created_at + token.expires_in.seconds, format: :short) %>
                          <% else %>
                            <%= t('.developer.tokens.no_expiry') %>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="text-muted mb-0"><%= t('.developer.tokens.none') %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>