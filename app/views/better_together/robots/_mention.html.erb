<%# locals: (robot:, flex_layout: 'flex-row', flex_align_items: 'left')%>

<div class="position-relative mention py-2 me-2 d-flex justify-content-center row-gap-1 <%= flex_layout %> <%= "align-items-#{flex_align_items}" %> mention_robot" id="<%= dom_id(robot, :mention) %>">
  <div class="h-50 d-flex align-items-center justify-content-center rounded-circle bg-body-secondary text-body-emphasis" style="width: 50px; height: 50px;">
    <i class="fas fa-robot" aria-hidden="true"></i>
    <span class="visually-hidden">Robot author</span>
  </div>
  <div class="h-50 align-self-top">
    <span class="identity-name d-block"><%= robot.name %></span>
    <small class="text-muted">Robot</small>
  </div>
</div>
