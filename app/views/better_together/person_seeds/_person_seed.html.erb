<div id="<%= dom_id seed %>" class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h5 class="card-title mb-1">
          <%= seed.identifier %>
          <span class="badge bg-secondary ms-1"><%= seed.version %></span>
          <span class="badge bg-info ms-1"><%= seed.type.demodulize %></span>
        </h5>
        <p class="card-text text-muted mb-1"><%= seed.description %></p>
        <small class="text-muted">
          <%= t('seeds.seeded_by', created_by: seed.created_by) %>
          <% if seed.seeded_at %>
            &middot; <%= l(seed.seeded_at, format: :short) %>
          <% end %>
        </small>
      </div>
      <div class="d-flex gap-1">
        <%= link_to person_seed_path(seed, locale: locale),
                    class: 'btn btn-outline-secondary btn-sm',
                    'aria-label' => t('seeds.actions.show') do %>
          <i class="fas fa-eye" aria-hidden="true"></i>
        <% end %>
        <% if seed.yaml_file.attached? %>
          <%= link_to rails_blob_path(seed.yaml_file, disposition: 'attachment'),
                      class: 'btn btn-outline-secondary btn-sm',
                      'aria-label' => t('seeds.show.download_yaml') do %>
            <i class="fas fa-download" aria-hidden="true"></i>
          <% end %>
        <% end %>
        <%= link_to person_seed_path(seed, locale: locale),
                    data: { 'turbo-method': 'delete', turbo_confirm: t('person_seeds.confirm_destroy') },
                    class: 'btn btn-outline-danger btn-sm',
                    'aria-label' => t('seeds.actions.destroy') do %>
          <i class="fas fa-trash-alt" aria-hidden="true"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>
