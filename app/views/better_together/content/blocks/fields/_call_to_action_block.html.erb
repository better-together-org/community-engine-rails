<%# locals: (block:, scope: BetterTogether::Content::Block.block_name, temp_id: SecureRandom.uuid) -%>
<%- temp_id = temp_id_for(block, temp_id:) %>
<div class="call-to-action-block-fields">
  <div class="mb-3">
    <%= label_tag "#{scope}[layout]", BetterTogether::Content::Block.human_attribute_name('layout', default: 'Layout'), class: 'form-label' %>
    <%= select_tag "#{scope}[layout]",
                   options_for_select(
                     BetterTogether::Content::CallToActionBlock::LAYOUTS.map do |l|
                       [t("better_together.content.blocks.call_to_action_block.layouts.#{l}", default: l.humanize), l]
                     end,
                     block.layout
                   ),
                   class: 'form-select',
                   data: { controller: 'better_together--slim-select' } %>
  </div>

  <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
             locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'heading' } %>

  <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
             locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'subheading' } %>

  <%= render partial: 'better_together/content/blocks/fields/shared/translatable_text_field',
             locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'body_text', rows: 3 } %>

  <div class="row row-cols-1 row-cols-sm-2 mb-3">
    <div class="col mb-3">
      <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
                 locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'primary_button_label',
                           help_text: 'Button label (e.g., "Get started")' } %>
    </div>
    <div class="col mb-3">
      <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
                 locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'primary_button_url',
                           help_text: 'Link destination (https://...)' } %>
    </div>
  </div>

  <div class="row row-cols-1 row-cols-sm-2 mb-3">
    <div class="col mb-3">
      <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
                 locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'secondary_button_label',
                           help_text: 'Optional secondary button label' } %>
    </div>
    <div class="col mb-3">
      <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
                 locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'secondary_button_url',
                           help_text: 'Optional secondary button link' } %>
    </div>
  </div>
</div>
