<%# locals: (block:, scope: BetterTogether::Content::Block.block_name, temp_id: SecureRandom.uuid) -%>
<%- temp_id = temp_id_for(block, temp_id:) %>
<div class="statistics-block-fields">
  <div class="row row-cols-1 row-cols-sm-2 mb-3">
    <div class="col mb-3">
      <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
                 locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'heading',
                           help_text: 'Optional heading for the statistics' } %>
    </div>
    <div class="col mb-3">
      <%= label_tag "#{scope}[columns]", BetterTogether::Content::Block.human_attribute_name('columns', default: 'Columns'), class: 'form-label' %>
      <%= select_tag "#{scope}[columns]",
                     options_for_select(
                       BetterTogether::Content::StatisticsBlock::COLUMN_OPTIONS.map { |c| [c, c] },
                       block.columns
                     ),
                     class: 'form-select',
                     data: { controller: 'better_together--slim-select' } %>
    </div>
  </div>

  <%= render layout: 'better_together/content/blocks/fields/shared/translatable_field',
             locals: { model: block, scope: scope, temp_id: temp_id, attribute: 'stats_json' } do |locale_attribute| %>
    <div class="mb-3">
      <label class="form-label"><%= BetterTogether::Content::Block.human_attribute_name('stats_json', default: 'Statistics') %></label>

      <div data-controller="better_together--json-array-rows"
           data-better_together--json-array-rows-keys-value='["label","value","icon"]'>

        <input type="hidden"
               name="<%= scope %>[<%= locale_attribute %>]"
               data-better_together--json-array-rows-target="jsonField"
               value="<%= h(block.public_send(locale_attribute).presence || '[]') %>">

      <div data-better_together--json-array-rows-target="container" class="statistics-rows mb-3"></div>

      <template data-better_together--json-array-rows-target="template">
        <div class="statistics-row card mb-2 position-relative" data-better_together--json-array-rows-target="row" draggable="true">
          <div class="card-body">
            <div class="row g-2 mb-2">
              <div class="col">
                <button type="button"
                        class="btn btn-sm btn-link text-muted p-0 drag-handle"
                        title="<%= t('better_together.content.blocks.json_array_rows.drag_handle', default: 'Drag to reorder') %>"
                        style="cursor: grab;">
                  <i class="fas fa-grip-vertical fa-lg" aria-hidden="true"></i>
                  <span class="visually-hidden"><%= t('better_together.content.blocks.json_array_rows.drag_handle', default: 'Drag to reorder') %></span>
                </button>
              </div>
              <div class="col-auto">
                <button type="button"
                        class="btn btn-sm btn-link text-muted p-0"
                        title="<%= t('better_together.content.blocks.json_array_rows.move_up', default: 'Move up') %>"
                        data-action="click->better_together--json-array-rows#moveUp">
                  <i class="fas fa-arrow-up" aria-hidden="true"></i>
                  <span class="visually-hidden"><%= t('better_together.content.blocks.json_array_rows.move_up', default: 'Move up') %></span>
                </button>
              </div>
              <div class="col-auto">
                <button type="button"
                        class="btn btn-sm btn-link text-muted p-0"
                        title="<%= t('better_together.content.blocks.json_array_rows.move_down', default: 'Move down') %>"
                        data-action="click->better_together--json-array-rows#moveDown">
                  <i class="fas fa-arrow-down" aria-hidden="true"></i>
                  <span class="visually-hidden"><%= t('better_together.content.blocks.json_array_rows.move_down', default: 'Move down') %></span>
                </button>
              </div>
              <div class="col-auto">
                <button type="button"
                        class="btn btn-sm btn-link text-danger p-0"
                        title="<%= t('better_together.content.blocks.json_array_rows.remove_item', default: 'Remove') %>"
                        data-action="click->better_together--json-array-rows#removeRow">
                  <i class="fas fa-trash-alt" aria-hidden="true"></i>
                  <span class="visually-hidden"><%= t('better_together.content.blocks.json_array_rows.remove_item', default: 'Remove') %></span>
                </button>
              </div>
            </div>

            <div class="row g-2 mb-2">
              <div class="col">
                <label class="form-label small"><%= t('better_together.content.blocks.statistics_block.label', default: 'Label') %></label>
                <input type="text"
                       class="form-control form-control-sm"
                       data-json-key="label"
                       placeholder="<%= t('better_together.content.blocks.statistics_block.label_placeholder', default: 'e.g., Members') %>">
              </div>
              <div class="col">
                <label class="form-label small"><%= t('better_together.content.blocks.statistics_block.value', default: 'Value') %></label>
                <input type="text"
                       class="form-control form-control-sm"
                       data-json-key="value"
                       placeholder="<%= t('better_together.content.blocks.statistics_block.value_placeholder', default: 'e.g., 500') %>">
              </div>
            </div>

            <div class="mb-2">
              <label class="form-label small"><%= t('better_together.content.blocks.statistics_block.icon', default: 'Icon (Font Awesome class, optional)') %></label>
              <input type="text"
                     class="form-control form-control-sm"
                     data-json-key="icon"
                     placeholder="<%= t('better_together.content.blocks.statistics_block.icon_placeholder', default: 'e.g., fas fa-users') %>">
            </div>
          </div>
        </div>
      </template>

      <button type="button"
              class="btn btn-sm btn-outline-primary"
              data-action="click->better_together--json-array-rows#addRow">
        <i class="fas fa-plus" aria-hidden="true"></i>
        <%= t('better_together.content.blocks.json_array_rows.add_item', default: 'Add item') %>
      </button>
    </div>
    </div>
  <% end %>
</div>
