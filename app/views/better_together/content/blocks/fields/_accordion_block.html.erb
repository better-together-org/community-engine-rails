<%# locals: (block:, scope: BetterTogether::Content::Block.block_name, temp_id: SecureRandom.uuid) -%>
<%- temp_id = temp_id_for(block, temp_id:) %>
<div class="accordion-block-fields">
  <div class="row row-cols-1 row-cols-sm-2 mb-3">
    <div class="col mb-3">
      <%= label_tag "#{scope}[heading]", BetterTogether::Content::Block.human_attribute_name('heading', default: 'Heading (optional)'), class: 'form-label' %>
      <%= text_field_tag "#{scope}[heading]", block.heading, class: 'form-control', placeholder: 'Frequently Asked Questions' %>
    </div>
    <div class="col mb-3 d-flex align-items-end">
      <div class="form-check">
        <%= check_box_tag "#{scope}[open_first]", 'true', block.open_first == 'true',
                          class: 'form-check-input', id: "#{scope}_open_first" %>
        <%= label_tag "#{scope}_open_first",
                      BetterTogether::Content::Block.human_attribute_name('open_first', default: 'Open first item by default'),
                      class: 'form-check-label' %>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= label_tag "#{scope}[accordion_items_json]", BetterTogether::Content::Block.human_attribute_name('accordion_items_json', default: 'Items (JSON)'), class: 'form-label' %>
    <%= text_area_tag "#{scope}[accordion_items_json]", block.accordion_items_json,
                      class: 'form-control font-monospace', rows: 10,
                      placeholder: '[{"question":"What is Better Together?","answer":"A community platform for co-operative organizations."}]' %>
    <div class="form-text">
      <%= t('better_together.content.blocks.accordion_block.items_json_help',
            default: 'JSON array of objects with "question" and "answer" keys.') %>
    </div>
  </div>
</div>
