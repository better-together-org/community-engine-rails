<%# locals: (block:, scope: BetterTogether::Content::Block.block_name, temp_id: SecureRandom.uuid) -%>
<%- temp_id = temp_id_for(block, temp_id:) %>
<div class="events-block-fields">
  <div class="mb-3">
    <%= label_tag "#{scope}[event_scope]", BetterTogether::Content::Block.human_attribute_name('event_scope', default: 'Event Scope'), class: 'form-label' %>
    <%= select_tag "#{scope}[event_scope]",
                   options_for_select(
                     BetterTogether::Content::EventsBlock::EVENT_SCOPES.map do |s|
                       [t("better_together.content.blocks.events_block.scopes.#{s}", default: s.humanize), s]
                     end,
                     block.event_scope
                   ),
                   class: 'form-select',
                   data: { controller: 'better_together--slim-select' } %>
  </div>

  <%= render partial: 'better_together/content/blocks/fields/shared/resource_block_fields',
             locals: { block:, scope:, temp_id: } %>
</div>
