<%# Shared form fields for resource collection blocks.
    locals: (block:, scope:, temp_id:, resource_class:) -%>
<%- available_communities = policy_scope(BetterTogether::Community).includes(:string_translations)
                                                               .sort_by { |community| community.name.to_s.downcase } %>

<div class="resource-block-fields">
  <div class="row row-cols-1 row-cols-sm-2 mb-3">
    <div class="col mb-3">
      <%= label_tag "#{scope}[display_style]", BetterTogether::Content::Block.human_attribute_name('display_style', default: 'Display Style'), class: 'form-label' %>
      <%= select_tag "#{scope}[display_style]",
                     options_for_select(
                       [['Grid', 'grid'], ['List', 'list']],
                       block.display_style
                     ),
                     class: 'form-select',
                     data: { controller: 'better_together--slim-select' } %>
    </div>

    <div class="col mb-3">
      <%= label_tag "#{scope}[item_limit]", BetterTogether::Content::Block.human_attribute_name('item_limit', default: 'Max Items'), class: 'form-label' %>
      <%= number_field_tag "#{scope}[item_limit]", block.item_limit, class: 'form-control', min: 1, max: 50 %>
    </div>
  </div>

  <div class="mb-3">
    <%= label_tag "#{scope}[community_scope_id]", BetterTogether::Content::Block.human_attribute_name('community_scope_id', default: 'Scope to Community (optional)'), class: 'form-label' %>
    <%= select_tag "#{scope}[community_scope_id]",
                   options_for_select(
                     available_communities.map { |c| [c.name, c.id] },
                     block.community_scope_id
                   ),
                   include_blank: t('better_together.content.blocks.resource_block.all_communities', default: 'All communities (platform-wide)'),
                   class: 'form-select',
                   data: { controller: 'better_together--slim-select' } %>
  </div>

  <div class="mb-3">
    <label class="form-label"><%= BetterTogether::Content::Block.human_attribute_name('resource_ids', default: 'Specific Records (optional)') %></label>

    <%# Hidden field carries the JSON string that the model reads %>
    <input type="hidden"
           id="<%= "#{scope}_resource_ids_json" %>"
           name="<%= scope %>[resource_ids]"
           value="<%= h(block.resource_ids) %>">

    <%# Multi-select is display-only — SlimSelect JS writes selected values to the hidden field %>
    <select class="form-select"
            data-controller="better_together--slim-select"
            data-slim-select-json-field-id="<%= "#{scope}_resource_ids_json" %>"
            data-better_together--slim-select-options-value='<%= {
              multiSelectJson: true,
              ajax: { url: resource_search_content_blocks_path(resource_class: resource_class.name, locale: I18n.locale) }
            }.to_json %>'>
      <%# Server-render currently saved records as pre-selected options so SlimSelect can set them on connect %>
      <% block.parsed_resource_ids.each do |id| %>
        <% record = resource_class.find_by(id:) %>
        <% next unless record %>
        <option value="<%= id %>" selected><%= record.to_s %></option>
      <% end %>
    </select>

    <div class="form-text">
      <%= t('better_together.content.blocks.resource_block.resource_ids_help',
             default: 'If set, only these records will be displayed, ignoring the community scope and ordering.') %>
    </div>
  </div>

  <div class="row row-cols-1 row-cols-sm-2 mb-3">
    <div class="col mb-3">
      <div class="form-check">
        <%= check_box_tag "#{scope}[show_view_more_link]", 'true', block.show_view_more_link == 'true',
                          class: 'form-check-input', id: "#{scope}_show_view_more_link" %>
        <%= label_tag "#{scope}_show_view_more_link",
                      BetterTogether::Content::Block.human_attribute_name('show_view_more_link', default: 'Show "View all" link'),
                      class: 'form-check-label' %>
      </div>
    </div>

    <div class="col mb-3">
      <%= render partial: 'better_together/content/blocks/fields/shared/translatable_string_field',
                 locals: { model: block, scope: scope, temp_id: temp_id || SecureRandom.uuid, attribute: 'view_more_url',
                           help_text: '"View all" link destination (https://...)' } %>
    </div>
  </div>
</div>
