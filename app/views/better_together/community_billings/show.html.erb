<% content_for :page_title do %>
  <%= t('better_together.billing.page_title', default: 'Community Billing') %> | <%= @community.name %>
<% end %>

<div class="container my-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
      <h1 class="mb-1"><%= t('better_together.billing.heading', default: 'Community Billing') %></h1>
      <p class="text-muted mb-0">
        <%= t('better_together.billing.subheading',
              default: 'Choose a hosted community plan, confirm who is paying, and manage sponsorship and billing access for this community.') %>
      </p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to t('globals.edit', default: 'Edit'),
                  edit_community_path(@community, locale: I18n.locale),
                  class: 'btn btn-outline-secondary' %>
      <%= button_to t('better_together.billing.reconcile_now', default: 'Reconcile now'),
                    reconcile_community_billing_path(@community, locale: I18n.locale),
                    method: :post,
                    class: 'btn btn-outline-secondary' %>
      <%= button_to t('better_together.billing.open_portal', default: 'Open billing portal'),
                    portal_community_billing_path(@community, locale: I18n.locale),
                    method: :post,
                    class: 'btn btn-outline-primary' %>
    </div>
  </div>

  <% if flash[:provision_url].present? %>
    <div class="alert alert-success d-flex align-items-center gap-3 mb-4" role="alert">
      <div>
        <strong><%= t('better_together.billing.platform_provisioned_success', default: 'Platform provisioned') %></strong>
        &mdash;
        <%= link_to t('better_together.billing.platform_provisioned_visit', default: 'Visit your new platform'),
                    flash[:provision_url],
                    target: '_blank', rel: 'noopener noreferrer',
                    class: 'alert-link' %>
      </div>
    </div>
  <% end %>

  <div class="row g-4">
    <div class="col-lg-4">
      <%= render 'better_together/shared/hosted_entitlement_card',
                 hosted_entitlement: @hosted_entitlement,
                 provision_path: provision_platform_community_billing_path(@community, locale: I18n.locale) %>

      <div class="card h-100">
        <div class="card-header">
          <strong><%= t('better_together.billing.current_subscription', default: 'Current subscription') %></strong>
        </div>
        <div class="card-body">
          <% if @billing_subscription.present? %>
            <% if @billing_subscription.portal_access_issue? %>
              <div class="alert alert-warning">
                <strong><%= t('better_together.billing.portal_access_attention', default: 'Billing portal access needs attention.') %></strong>
                <div><%= @billing_subscription.last_portal_error_message.presence || t('better_together.billing.portal_access_attention_fallback', default: 'The last portal access attempt did not complete successfully.') %></div>
                <div class="small mb-0">
                  <%= t('better_together.billing.portal_access_last_failed_at', default: 'Last failed attempt:') %>
                  <strong><%= l(@billing_subscription.last_portal_error_at, format: :long) if @billing_subscription.last_portal_error_at %></strong>
                </div>
              </div>
            <% end %>
            <p class="mb-2"><strong><%= @billing_subscription.billing_plan.name %></strong></p>
            <p class="mb-2">
              <span class="badge text-bg-primary"><%= @billing_subscription.status %></span>
            </p>
            <p class="mb-1">
              <%= t('better_together.billing.last_synced_at', default: 'Last synced:') %>
              <strong><%= l(@billing_subscription.last_synced_at, format: :long) if @billing_subscription.last_synced_at %></strong>
            </p>
            <p class="mb-1">
              <%= t('better_together.billing.sync_source', default: 'Sync source:') %>
              <strong><%= @billing_subscription.sync_source.presence || t('better_together.billing.unknown_sync_source', default: 'Unknown') %></strong>
            </p>
            <p class="mb-1">
              <%= t('better_together.billing.current_period_ends', default: 'Current period ends:') %>
              <strong><%= l(@billing_subscription.current_period_end, format: :long) if @billing_subscription.current_period_end %></strong>
            </p>
            <% if @billing_subscription.billable_owner != @billing_subscription.beneficiary %>
              <p class="mb-1">
                <%= t('better_together.billing.billed_to', default: 'Billed to:') %>
                <strong><%= @billing_subscription.billable_owner.name %></strong>
              </p>
              <div class="alert alert-warning mt-3 mb-0">
                <p class="mb-2">
                  <%= t(
                        'better_together.billing.sponsored_subscription_notice',
                        default: 'This community is currently sponsored by %{owner}. Start a new checkout below if you want to take over billing with a different owner.',
                        owner: @billing_subscription.billable_owner.name
                      ) %>
                </p>
                <% if @current_billing_plan.present? %>
                  <div class="d-flex flex-wrap gap-2">
                    <% if @current_billing_plan.eligible_for?(@community) %>
                      <%= button_to t('better_together.billing.takeover_as_community', default: 'Switch billing to this community'),
                                    checkout_community_billing_path(@community, billing_plan_id: @current_billing_plan.id, locale: I18n.locale),
                                    method: :post,
                                    class: 'btn btn-warning btn-sm' %>
                    <% end %>
                    <% if @sponsoring_person.present? &&
                          @sponsoring_person != @billing_subscription.billable_owner &&
                          @current_billing_plan.eligible_for?(@sponsoring_person) %>
                      <%= button_to t('better_together.billing.takeover_as_person', default: 'Pay personally instead'),
                                    checkout_community_billing_path(
                                      @community,
                                      billing_plan_id: @current_billing_plan.id,
                                      checkout_as: 'person',
                                      locale: I18n.locale
                                    ),
                                    method: :post,
                                    class: 'btn btn-outline-warning btn-sm' %>
                    <% end %>
                    <% @sponsoring_communities.each do |sponsoring_community| %>
                      <% next if sponsoring_community == @billing_subscription.billable_owner %>
                      <% next unless @current_billing_plan.eligible_for?(sponsoring_community) %>

                      <%= button_to t(
                            'better_together.billing.takeover_as_other_community',
                            default: 'Pay via %{community} instead',
                            community: sponsoring_community.name
                          ),
                                    checkout_community_billing_path(
                                      @community,
                                      billing_plan_id: @current_billing_plan.id,
                                      checkout_as: 'community',
                                      billable_owner_community_id: sponsoring_community.id,
                                      locale: I18n.locale
                                    ),
                                    method: :post,
                                    class: 'btn btn-outline-warning btn-sm' %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <p class="mb-0">
              <%= t('better_together.billing.cancel_at_period_end', default: 'Cancel at period end:') %>
              <strong><%= @billing_subscription.cancel_at_period_end? ? t('globals.yes', default: 'Yes') : t('globals.no', default: 'No') %></strong>
            </p>
          <% else %>
            <p class="mb-0 text-muted">
              <%= t('better_together.billing.no_subscription', default: 'No synced subscription is recorded for this community yet.') %>
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center gap-2">
          <strong><%= t('better_together.billing.merchant_account', default: 'Merchant account') %></strong>
          <div class="d-flex gap-2">
            <% if @merchant_account.present? %>
              <%= button_to t('better_together.billing.refresh_merchant_account', default: 'Refresh merchant status'),
                            refresh_merchant_account_community_billing_path(@community, locale: I18n.locale),
                            method: :post,
                            class: 'btn btn-outline-secondary btn-sm' %>
            <% end %>
            <%= button_to t('better_together.billing.open_merchant_onboarding', default: 'Open merchant onboarding'),
                          merchant_onboarding_community_billing_path(@community, locale: I18n.locale),
                          method: :post,
                          class: 'btn btn-outline-primary btn-sm' %>
          </div>
        </div>
        <div class="card-body">
          <% if @merchant_account.present? %>
            <% if @merchant_account.support_attention_needed? %>
              <div class="alert <%= @merchant_account.support_state == :disconnected ? 'alert-danger' : 'alert-warning' %> mb-3">
                <% case @merchant_account.support_state %>
                <% when :disconnected %>
                  <strong><%= t('better_together.billing.merchant_disconnected_heading', default: 'Merchant account disconnected.') %></strong>
                  <div><%= t('better_together.billing.merchant_disconnected_body', default: 'Stripe deauthorized this merchant connection or CE marked it disconnected. Reconnect onboarding before relying on payouts.') %></div>
                  <% if @merchant_account.deauthorized_at %>
                    <div class="small mb-0">
                      <%= t('better_together.billing.merchant_disconnected_at', default: 'Disconnected at:') %>
                      <strong><%= l(@merchant_account.deauthorized_at, format: :long) %></strong>
                    </div>
                  <% end %>
                <% when :required_action %>
                  <strong><%= t('better_together.billing.merchant_required_action_heading', default: 'Merchant onboarding still needs action.') %></strong>
                  <div><%= t('better_together.billing.merchant_required_action_body', default: 'Stripe still needs more information or review before this merchant account can receive payouts.') %></div>
                <% when :restricted, :disabled, :errored, :capability_gap %>
                  <strong><%= t('better_together.billing.merchant_support_attention_heading', default: 'Merchant account needs support attention.') %></strong>
                  <div><%= t('better_together.billing.merchant_support_attention_body', default: 'This merchant account is not currently payout-ready. Review the status below and refresh from Stripe after any corrective action.') %></div>
                <% end %>
              </div>
            <% end %>
            <p class="mb-2">
              <span class="badge text-bg-info"><%= @merchant_account.status %></span>
            </p>
            <p class="mb-1">
              <%= t('better_together.billing.merchant_provider', default: 'Provider:') %>
              <strong><%= @merchant_account.provider %></strong>
            </p>
            <p class="mb-1">
              <%= t('better_together.billing.merchant_charges_enabled', default: 'Charges enabled:') %>
              <strong><%= @merchant_account.charges_enabled? ? t('globals.yes', default: 'Yes') : t('globals.no', default: 'No') %></strong>
            </p>
            <p class="mb-1">
              <%= t('better_together.billing.merchant_payouts_enabled', default: 'Payouts enabled:') %>
              <strong><%= @merchant_account.payouts_enabled? ? t('globals.yes', default: 'Yes') : t('globals.no', default: 'No') %></strong>
            </p>
            <p class="mb-0 text-muted">
              <%= t(
                    'better_together.billing.merchant_connect_explainer_community',
                    default: 'Connect Stripe so this community can complete onboarding and receive payouts in later commerce flows.'
                  ) %>
            </p>
          <% else %>
            <p class="mb-2 text-muted">
              <%= t(
                    'better_together.billing.merchant_not_connected',
                    default: 'No merchant account is connected yet.'
                  ) %>
            </p>
            <p class="mb-0 text-muted">
              <%= t(
                    'better_together.billing.merchant_connect_explainer_community',
                    default: 'Connect Stripe so this community can complete onboarding and receive payouts in later commerce flows.'
                  ) %>
            </p>
          <% end %>
        </div>
      </div>

      <%= render 'better_together/shared/billing_event_alerts',
                 billing_alert_events: @billing_alert_events,
                 billing_alert_summary: @billing_alert_summary,
                 replay_billing_event_path: ->(billing_event) do
                   replay_event_community_billing_path(@community, event_id: billing_event.id, locale: I18n.locale)
                 end,
                 last_billing_event: @last_billing_event %>

      <div class="card">
        <div class="card-header">
          <strong><%= t('better_together.billing.available_plans', default: 'Available hosted plans') %></strong>
        </div>
        <div class="card-body">
          <div class="alert alert-info">
            <strong><%= t('better_together.billing.hosted_plan_scope_heading', default: 'Hosted plans available now') %></strong>
            <div><%= t('better_together.billing.hosted_plan_scope_body', default: 'These recurring plans support this community space directly. One-time payment plans are intentionally excluded from the current launch path until their fulfillment flow is completed.') %></div>
          </div>
          <% if @billing_plans.any? %>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead>
                  <tr>
                    <th><%= t('globals.name', default: 'Name') %></th>
                    <th><%= t('better_together.billing.plan_value', default: 'What this plan supports') %></th>
                    <th><%= t('better_together.billing.interval', default: 'Interval') %></th>
                    <th><%= t('better_together.billing.price', default: 'Price') %></th>
                    <th class="text-end"><%= t('globals.actions', default: 'Actions') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% @billing_plans.each do |billing_plan| %>
                    <tr>
                      <td><strong><%= billing_plan.name %></strong></td>
                      <td><%= render 'better_together/shared/billing_plan_details', billing_plan: billing_plan %></td>
                      <td><%= billing_plan.billing_interval %></td>
                      <td><%= number_to_currency(billing_plan.amount_cents / 100.0, unit: billing_plan.currency.upcase == 'CAD' ? 'CA$' : "#{billing_plan.currency.upcase} ") %></td>
                      <td class="text-end">
                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                          <%= button_to t('better_together.billing.start_checkout', default: 'Start checkout'),
                                        checkout_community_billing_path(@community, billing_plan_id: billing_plan.id, locale: I18n.locale),
                                        method: :post,
                                        class: 'btn btn-primary btn-sm' %>
                          <% if @sponsoring_person.present? && billing_plan.eligible_for?(@sponsoring_person) %>
                            <%= button_to t('better_together.billing.sponsor_checkout', default: 'Pay personally for this community'),
                                          checkout_community_billing_path(
                                            @community,
                                            billing_plan_id: billing_plan.id,
                                            checkout_as: 'person',
                                            locale: I18n.locale
                                          ),
                                          method: :post,
                                          class: 'btn btn-outline-primary btn-sm' %>
                          <% end %>
                          <% @sponsoring_communities.each do |sponsoring_community| %>
                            <% next unless billing_plan.eligible_for?(sponsoring_community) %>

                            <%= button_to t(
                                  'better_together.billing.community_sponsor_checkout',
                                  default: 'Pay via %{community}',
                                  community: sponsoring_community.name
                                ),
                                          checkout_community_billing_path(
                                            @community,
                                            billing_plan_id: billing_plan.id,
                                            checkout_as: 'community',
                                            billable_owner_community_id: sponsoring_community.id,
                                            locale: I18n.locale
                                          ),
                                          method: :post,
                                          class: 'btn btn-outline-secondary btn-sm' %>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="mb-0 text-muted">
              <%= t('better_together.billing.no_plans', default: 'No recurring hosted billing plans are configured yet.') %>
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
