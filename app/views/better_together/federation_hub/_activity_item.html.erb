<%#
  Locals:
    activity (BetterTogether::Activity, required)
-%>
<li class="list-group-item d-flex justify-content-between align-items-start gap-2" id="<%= dom_id(activity) %>">
  <div>
    <%= link_to_trackable(activity.trackable, activity.trackable_type.to_s.demodulize) %>
    <div class="small text-muted">
      <%= t("better_together.federation_hub.activity.keys.#{activity.key.tr('.', '_')}",
            default: activity.key.humanize) %>
    </div>
  </div>
  <%= timeago(activity.created_at) %>
</li>
