<% return unless @show_platform_connection_review_section %>

<section aria-labelledby="platform-connection-review-heading" class="card shadow-sm mt-4">
  <div class="card-body">
    <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3 mb-3">
      <div>
        <h2 id="platform-connection-review-heading" class="h4 mb-2">
          <%= t('host_dashboard.platform_connection_review.heading') %>
        </h2>
        <p class="text-muted mb-0">
          <%= t('host_dashboard.platform_connection_review.description',
                total_connections: @platform_connection_review_total_count,
                pending_connections: @platform_connection_review_pending_count) %>
        </p>
      </div>

      <div class="d-flex flex-wrap gap-2 align-items-center">
        <div class="d-flex flex-wrap gap-2" aria-label="<%= t('host_dashboard.platform_connection_review.summary_label') %>">
          <span class="badge rounded-pill text-bg-secondary fs-6">
            <%= t('host_dashboard.platform_connection_review.total_badge', count: @platform_connection_review_total_count) %>
          </span>
          <span class="badge rounded-pill text-bg-warning fs-6">
            <%= t('host_dashboard.platform_connection_review.pending_badge', count: @platform_connection_review_pending_count) %>
          </span>
          <span class="badge rounded-pill text-bg-success fs-6">
            <%= t('host_dashboard.platform_connection_review.active_badge', count: @platform_connection_review_active_count) %>
          </span>
        </div>

        <%= link_to t('host_dashboard.platform_connection_review.review_link'),
                    platform_connections_path,
                    class: 'btn btn-outline-primary btn-sm' %>
      </div>
    </div>

    <% if @platform_connection_review_cards.blank? %>
      <p class="text-muted mb-0"><%= t('host_dashboard.platform_connection_review.no_connections') %></p>
    <% else %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <caption class="visually-hidden"><%= t('host_dashboard.platform_connection_review.table_caption') %></caption>
          <thead>
            <tr>
              <th scope="col"><%= t('host_dashboard.platform_connection_review.columns.connection') %></th>
              <th scope="col"><%= t('host_dashboard.platform_connection_review.columns.kind') %></th>
              <th scope="col"><%= t('host_dashboard.platform_connection_review.columns.status') %></th>
              <th scope="col"><%= t('host_dashboard.platform_connection_review.columns.latest_activity') %></th>
              <th scope="col" class="text-end"><%= t('host_dashboard.platform_connection_review.columns.actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% @platform_connection_review_cards.each do |card| %>
              <% connection = card[:connection] %>
              <% counterparty = card[:counterparty] %>
              <% status_badge_class =
                   case connection.status
                   when 'pending' then 'text-bg-warning'
                   when 'active' then 'text-bg-success'
                   when 'blocked' then 'text-bg-danger'
                   else 'text-bg-secondary'
                   end %>
              <tr>
                <th scope="row">
                  <div class="fw-semibold"><%= counterparty&.name || t('host_dashboard.platform_connection_review.unknown_platform') %></div>
                  <div class="text-muted small">
                    <%= t("host_dashboard.platform_connection_review.direction.#{card[:direction]}") %>
                  </div>
                </th>
                <td>
                  <span class="badge rounded-pill text-bg-secondary">
                    <%= t("better_together.enums.platform_connection.connection_kind.#{connection.connection_kind}") %>
                  </span>
                </td>
                <td>
                  <span class="badge rounded-pill <%= status_badge_class %>">
                    <%= t("better_together.enums.platform_connection.status.#{connection.status}") %>
                  </span>
                </td>
                <td>
                  <span class="text-muted">
                    <%= t('host_dashboard.platform_connection_review.status_updated_at',
                          time: time_ago_in_words(connection.updated_at)) %>
                  </span>
                </td>
                <td class="text-end">
                  <%= link_to t('host_dashboard.platform_connection_review.view_link'),
                              platform_connection_path(connection),
                              class: 'btn btn-outline-primary btn-sm' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</section>
