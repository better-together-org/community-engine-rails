<section aria-labelledby="membership-review-heading" class="card shadow-sm mt-4">
  <div class="card-body">
    <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3 mb-3">
      <div>
        <h2 id="membership-review-heading" class="h4 mb-2">
          <%= t('host_dashboard.membership_review.heading') %>
        </h2>
        <p class="text-muted mb-0">
          <%= t('host_dashboard.membership_review.description',
                open_requests: @membership_review_total_open_count,
                communities: @membership_review_open_community_count) %>
        </p>
      </div>

      <div class="d-flex flex-wrap gap-2" aria-label="<%= t('host_dashboard.membership_review.summary_label') %>">
        <span class="badge rounded-pill text-bg-primary fs-6">
          <%= t('host_dashboard.membership_review.open_requests_badge', count: @membership_review_total_open_count) %>
        </span>
        <span class="badge rounded-pill text-bg-secondary fs-6">
          <%= t('host_dashboard.membership_review.communities_badge', count: @membership_review_open_community_count) %>
        </span>
      </div>
    </div>

    <% if @membership_review_cards.blank? %>
      <p class="text-muted mb-0"><%= t('host_dashboard.membership_review.no_communities') %></p>
    <% else %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <caption class="visually-hidden"><%= t('host_dashboard.membership_review.table_caption') %></caption>
          <thead>
            <tr>
              <th scope="col"><%= t('host_dashboard.membership_review.columns.community') %></th>
              <th scope="col"><%= t('host_dashboard.membership_review.columns.open_requests') %></th>
              <th scope="col"><%= t('host_dashboard.membership_review.columns.latest_activity') %></th>
              <th scope="col"><%= t('host_dashboard.membership_review.columns.request_mode') %></th>
              <th scope="col" class="text-end"><%= t('host_dashboard.membership_review.columns.actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% @membership_review_cards.each do |card| %>
              <% community = card[:community] %>
              <% latest_requests = card[:latest_requests] %>
              <tr>
                <th scope="row">
                  <div class="fw-semibold"><%= community.name %></div>
                  <% if community.description.present? %>
                    <div class="text-muted small">
                      <%= truncate(strip_tags(community.description.to_s), length: 120) %>
                    </div>
                  <% end %>
                </th>
                <td>
                  <% badge_class = card[:open_count].positive? ? 'text-bg-warning' : 'text-bg-success' %>
                  <span class="badge rounded-pill <%= badge_class %>">
                    <%= t('host_dashboard.membership_review.open_requests_count', count: card[:open_count]) %>
                  </span>
                </td>
                <td>
                  <% if latest_requests.any? %>
                    <ul class="list-unstyled mb-0 small">
                      <% latest_requests.each do |request| %>
                        <li class="mb-1">
                          <span class="fw-semibold"><%= request.requestor_name.presence || request.creator&.name || t('host_dashboard.membership_review.anonymous_requester') %></span>
                          <span class="text-muted">
                            <%= t('host_dashboard.membership_review.requested_at', time: time_ago_in_words(request.created_at)) %>
                          </span>
                        </li>
                      <% end %>
                    </ul>
                  <% else %>
                    <span class="text-muted"><%= t('host_dashboard.membership_review.no_recent_requests') %></span>
                  <% end %>
                </td>
                <td>
                  <% request_mode_badge = card[:requests_enabled] ? 'text-bg-success' : 'text-bg-secondary' %>
                  <span class="badge rounded-pill <%= request_mode_badge %>">
                    <%= card[:requests_enabled] ? t('host_dashboard.membership_review.request_mode_open') : t('host_dashboard.membership_review.request_mode_closed') %>
                  </span>
                </td>
                <td class="text-end">
                  <%= link_to t('host_dashboard.membership_review.review_link'),
                              community_membership_requests_path(community),
                              class: 'btn btn-outline-primary btn-sm' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</section>
