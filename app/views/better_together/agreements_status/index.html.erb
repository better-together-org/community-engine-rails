<% content_for :page_title do %>
  <%= t('.title') %>
<% end %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="mb-4"><%= t('.title') %></h2>
      
      <div class="alert alert-info" role="alert">
        <%= t('.description_html') %>
      </div>

      <%= form_tag agreements_status_path(locale: I18n.locale), method: :post, class: 'needs-validation', novalidate: true, data: { controller: 'better_together--form-validation' } do %>
        <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

        <% @display_agreements.each do |entry| %>
          <% agreement = entry[:agreement] %>
          <% accepted = entry[:accepted] %>
          <% next if accepted %>
          <% param_name = agreement_acceptance_param_name(agreement) %>
          <% checkbox_id = agreement_acceptance_checkbox_id(agreement) %>
          <% help_id = "#{agreement.identifier.dasherize}-help" %>

          <div class="card mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                  <h5 class="card-title">
                    <%= agreement.title %>
                    <span class="badge bg-warning ms-2"><%= t('.not_accepted') %></span>
                  </h5>
                  <p class="card-text text-muted"><%= agreement.description %></p>
                </div>
              </div>

              <div class="mt-3">
                <%= link_to t('.view_agreement'),
                            agreement_path(agreement, locale: I18n.locale),
                            class: 'btn btn-sm btn-outline-primary agreement-modal-link',
                            role: 'button',
                            data: { agreement_identifier: agreement.identifier } %>
              </div>

              <div class="form-check mt-3">
                <%= check_box_tag param_name, '1', false,
                                  class: 'form-check-input agreement-checkbox',
                                  data: { agreement_identifier: agreement.identifier },
                                  required: true,
                                  aria: { describedby: help_id, disabled: 'true' },
                                  id: checkbox_id %>
                <%= label_tag param_name, t('.i_accept'),
                              class: 'form-check-label',
                              for: checkbox_id %>
                <small id="<%= help_id %>" class="form-text text-muted d-block">
                  <%= t('.must_view_to_accept') %>
                </small>
              </div>
            </div>
          </div>
        <% end %>

        <% if @unaccepted_agreements.any? %>
          <div class="text-center mt-4">
            <%= submit_tag t('.submit'), class: 'btn btn-primary btn-lg' %>
          </div>
        <% end %>
      <% end %>
      </div>
    </div>
  </div>
</div>
