<% content_for :page_title do %>
  <%= @plan.name %> | <%= t('better_together.billing.plans.index_title', default: 'Billing Plans') %>
<% end %>

<div id="<%= dom_id(@plan, :show_page) %>" class="container my-4">
  <%= render 'shared/resource_toolbar',
             back_to_list_path: billing_plans_path(locale: I18n.locale),
             edit_path: policy(@plan).edit? ? edit_billing_plan_path(@plan, locale: I18n.locale) : nil %>

  <div class="row g-4 mt-1">
    <div class="col-lg-6">
      <div id="<%= dom_id(@plan, :summary_card) %>" class="card">
        <div class="card-header">
          <strong><%= @plan.name %></strong>
          <% if @plan.active? %>
            <span class="badge bg-success ms-2 billing-plan-status-badge"><%= t('better_together.billing.plans.status_active', default: 'Active') %></span>
          <% else %>
            <span class="badge bg-secondary ms-2 billing-plan-status-badge"><%= t('better_together.billing.plans.status_inactive', default: 'Inactive') %></span>
          <% end %>
        </div>
        <div class="card-body">
          <dl id="<%= dom_id(@plan, :summary_details) %>" class="row mb-0">
            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_identifier', default: 'Identifier') %></dt>
            <dd id="<%= dom_id(@plan, :identifier) %>" class="col-sm-7"><code><%= @plan.identifier %></code></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_description', default: 'Description') %></dt>
            <dd id="<%= dom_id(@plan, :description) %>" class="col-sm-7"><%= @plan.description.presence || '—' %></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_billing_interval', default: 'Interval') %></dt>
            <dd id="<%= dom_id(@plan, :billing_interval) %>" class="col-sm-7">
              <%= t("better_together.billing.plans.interval_#{@plan.billing_interval}",
                    default: @plan.billing_interval.humanize) %>
            </dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_amount_cents', default: 'Price') %></dt>
            <dd id="<%= dom_id(@plan, :price) %>" class="col-sm-7">
              <%= number_to_currency(@plan.amount_cents / 100.0, unit: @plan.currency + ' ') %>
            </dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_stripe_price_id', default: 'Stripe Price ID') %></dt>
            <dd id="<%= dom_id(@plan, :stripe_price_id) %>" class="col-sm-7"><code><%= @plan.stripe_price_id %></code></dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div id="<%= dom_id(@plan, :metadata_card) %>" class="card">
        <div class="card-header">
          <strong><%= t('better_together.billing.plans.metadata_section_title', default: 'Plan metadata') %></strong>
        </div>
        <div class="card-body">
          <dl id="<%= dom_id(@plan, :metadata_details) %>" class="row mb-0">
            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_participant_summary', default: 'Participant summary') %></dt>
            <dd id="<%= dom_id(@plan, :participant_summary) %>" class="col-sm-7"><%= @plan.participant_summary.presence || '—' %></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_participant_benefits', default: 'Benefits') %></dt>
            <dd id="<%= dom_id(@plan, :participant_benefits) %>" class="col-sm-7">
              <% if @plan.participant_benefits.any? %>
                <ul class="mb-0 ps-3">
                  <% @plan.participant_benefits.each do |benefit| %>
                    <li><%= benefit %></li>
                  <% end %>
                </ul>
              <% else %>
                —
              <% end %>
            </dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_beneficiary_label', default: 'Beneficiary label') %></dt>
            <dd id="<%= dom_id(@plan, :beneficiary_label) %>" class="col-sm-7"><%= @plan.beneficiary_label.presence || '—' %></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_hosted_access_level', default: 'Hosted access level') %></dt>
            <dd id="<%= dom_id(@plan, :hosted_access_level) %>" class="col-sm-7"><%= @plan.hosted_access_level.presence || '—' %></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_support_tier', default: 'Support tier') %></dt>
            <dd id="<%= dom_id(@plan, :support_tier) %>" class="col-sm-7"><%= @plan.support_tier.presence || '—' %></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_community_capacity_tier', default: 'Capacity tier') %></dt>
            <dd id="<%= dom_id(@plan, :community_capacity_tier) %>" class="col-sm-7"><%= @plan.community_capacity_tier.presence || '—' %></dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_eligible_owner_types', default: 'Eligible for') %></dt>
            <dd id="<%= dom_id(@plan, :eligible_owner_types) %>" class="col-sm-7">
              <% @plan.eligible_billable_owner_types.each do |type| %>
                <span class="badge bg-light text-dark border me-1">
                  <%= type.demodulize %>
                </span>
              <% end %>
            </dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_pricing_tier', default: 'Pricing tier') %></dt>
            <dd id="<%= dom_id(@plan, :pricing_tier) %>" class="col-sm-7">
              <span class="badge <%= @plan.solidarity_tier? ? 'bg-info text-dark' : 'bg-secondary' %>">
                <%= t("better_together.billing.plans.pricing_tier_#{@plan.pricing_tier}",
                      default: @plan.pricing_tier.humanize) %>
              </span>
            </dd>

            <dt class="col-sm-5"><%= t('better_together.billing.plans.field_solidarity_description', default: 'Solidarity description') %></dt>
            <dd id="<%= dom_id(@plan, :solidarity_description) %>" class="col-sm-7"><%= @plan.solidarity_description.presence || '—' %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <% if @subscription_health.any? %>
    <div id="<%= dom_id(@plan, :subscription_health_card) %>" class="card mt-4">
      <div class="card-header">
        <strong><%= t('better_together.billing.plans.subscription_health_title', default: 'Subscription health') %></strong>
      </div>
      <div class="card-body">
        <div class="d-flex flex-wrap gap-3">
          <% @subscription_health.each do |status, count| %>
            <div class="text-center">
              <div class="fs-4 fw-bold"><%= count %></div>
              <div class="small text-muted">
                <%= t("better_together.billing.subscription_status.#{status}", default: status.humanize) %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @recent_subscribers.any? %>
    <div id="<%= dom_id(@plan, :recent_subscribers_card) %>" class="card mt-4">
      <div class="card-header">
        <strong><%= t('better_together.billing.plans.recent_subscribers_title', default: 'Active subscribers') %></strong>
        <span class="badge bg-primary rounded-pill ms-2"><%= @recent_subscribers.size %></span>
      </div>
      <div class="card-body p-0">
        <ul class="list-group list-group-flush">
          <% @recent_subscribers.each do |subscription| %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <% sub_owner = subscription.pay_subscription&.owner %>
              <span><%= sub_owner&.try(:name) || subscription.pay_subscription_id %></span>
              <span class="badge bg-light text-dark border">
                <%= sub_owner&.class&.model_name&.human || '—'%>
              </span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
</div>
