<%= render layout: 'layouts/better_together/host_nav' do %>
  <% content_for :page_title do %>
    <%= t('better_together.platform_connections.index.title') %>
  <% end %>

  <div class="container my-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1><%= t('better_together.platform_connections.index.title') %></h1>
      <% if policy(BetterTogether::PlatformConnection).create? %>
        <%= link_to t('better_together.platform_connections.index.new_connection'), better_together.new_platform_connection_path, class: 'btn btn-primary' %>
      <% end %>
    </div>

    <div class="row">
      <div class="col table-responsive">
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th><%= t('better_together.platform_connections.index.columns.source') %></th>
              <th><%= t('better_together.platform_connections.index.columns.target') %></th>
              <th><%= t('better_together.platform_connections.index.columns.status') %></th>
              <th><%= t('better_together.platform_connections.index.columns.kind') %></th>
              <th><%= t('better_together.platform_connections.index.columns.content_policy') %></th>
              <th><%= t('better_together.platform_connections.index.columns.auth_policy') %></th>
              <th class="text-end"><%= t('globals.actions') %></th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: 'better_together/platform_connections/platform_connection', collection: @platform_connections %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
