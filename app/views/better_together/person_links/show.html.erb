<section class="container py-4">
  <header class="mb-4">
    <p class="text-muted mb-2">
      <%= link_to t('better_together.person_links.show.back', default: 'Back to linked people'),
                  person_links_path,
                  class: 'text-decoration-none' %>
    </p>
    <h1><%= t('better_together.person_links.show.title', default: 'Person Link') %></h1>
    <p class="text-muted mb-0"><%= @person_link.status.humanize %></p>
  </header>

  <dl class="row mb-4">
    <dt class="col-sm-3">Source person</dt>
    <dd class="col-sm-9"><%= @person_link.source_person.name %></dd>

    <dt class="col-sm-3">Target person</dt>
    <dd class="col-sm-9"><%= @person_link.target_person&.name || @person_link.remote_target_name || @person_link.remote_target_identifier %></dd>

    <dt class="col-sm-3">Platform connection</dt>
    <dd class="col-sm-9">
      <%= @person_link.platform_connection.source_platform.name %>
      →
      <%= @person_link.platform_connection.target_platform.name %>
    </dd>

    <dt class="col-sm-3">Verified</dt>
    <dd class="col-sm-9"><%= @person_link.verified_at ? l(@person_link.verified_at, format: :short) : 'Pending' %></dd>
  </dl>

  <% if @person_access_grants.any? %>
    <section class="mb-4">
      <h2 class="h5">Access Grants</h2>
      <ul>
        <% @person_access_grants.each do |grant| %>
          <li>
            <%= link_to person_access_grant_path(grant), class: 'text-decoration-none' do %>
              <%= grant.status.humanize %>:
              <%= grant.grantee_person&.name || grant.remote_grantee_name || grant.remote_grantee_identifier %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @person_link.source_person == current_person && !@person_link.revoked? %>
    <section>
      <%= button_to t('better_together.person_links.show.revoke', default: 'Revoke link'),
                    revoke_person_link_path(@person_link),
                    method: :post,
                    class: 'btn btn-outline-danger',
                    form: { data: { turbo_confirm: 'Revoke this person link and its access grants?' } } %>
    </section>
  <% end %>
</section>
