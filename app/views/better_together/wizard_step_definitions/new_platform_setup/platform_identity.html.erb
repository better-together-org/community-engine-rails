<% content_for :page_title do %>
  <%= t('.hero.title') %>
<% end %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <%= render 'better_together/wizard_step_definitions/new_platform_setup/progress', current_step_identifier: 'platform_identity' %>

      <h1 class="h3 mb-2"><%= t('.hero.title') %></h1>
      <p class="text-muted mb-4"><%= t('.hero.subtitle') %></p>

      <p class="mb-3"><%= t('.intro') %></p>

      <%= render 'better_together/wizard_step_definitions/new_platform_setup/errors', form_object: @form %>

      <%= form_for @form, url: new_platform_setup_step_create_platform_identity_path(platform_id: @platform.to_param),
                  method: :post, class: 'needs-validation', data: { controller: 'better_together--form-validation' } do |f| %>
        <div class="mb-3">
          <%= f.label :name, t('.fields.name.label'), for: 'new_platform_platform_name', class: 'form-label' %>
          <%= f.text_field :name, autofocus: true, id: 'new_platform_platform_name',
                           placeholder: t('.fields.name.placeholder'),
                           class: "form-control#{' is-invalid' if @form.errors[:name].any?}",
                           required: true, 'aria-describedby': 'new_platform_platform_name_help' %>
          <small id="new_platform_platform_name_help" class="form-text text-muted">
            <%= t('.fields.name.help') %>
          </small>
        </div>

        <div class="mb-3">
          <%= f.label :description, t('.fields.description.label'), for: 'new_platform_platform_description', class: 'form-label' %>
          <%= f.text_area :description, id: 'new_platform_platform_description',
                          placeholder: t('.fields.description.placeholder'),
                          class: "form-control#{' is-invalid' if @form.errors[:description].any?}",
                          rows: 3, required: true, 'aria-describedby': 'new_platform_platform_description_help' %>
          <small id="new_platform_platform_description_help" class="form-text text-muted">
            <%= t('.fields.description.help') %>
          </small>
        </div>

        <div class="mb-3">
          <%= f.label :host_url, t('.fields.host_url.label'), for: 'new_platform_platform_host_url', class: 'form-label' %>
          <%= f.text_field :host_url, id: 'new_platform_platform_host_url',
                           placeholder: t('.fields.host_url.placeholder'),
                           class: "form-control#{' is-invalid' if @form.errors[:host_url].any?}",
                           required: true, 'aria-describedby': 'new_platform_platform_host_url_help' %>
          <small id="new_platform_platform_host_url_help" class="form-text text-muted">
            <%= t('.fields.host_url.help') %>
          </small>
        </div>

        <div class="mb-3">
          <%= f.label :privacy, t('.fields.privacy.label'), for: 'new_platform_platform_privacy', class: 'form-label' %>
          <%= f.select :privacy, ::BetterTogether::Platform.privacies.keys.map { |privacy| [privacy.humanize, privacy] },
                       {}, { id: 'new_platform_platform_privacy', class: 'form-select', required: true,
                             'aria-describedby': 'new_platform_platform_privacy_help' } %>
          <small id="new_platform_platform_privacy_help" class="form-text text-muted">
            <%= t('.fields.privacy.help') %>
          </small>
        </div>

        <div class="mb-3">
          <%= f.label :time_zone, t('.fields.time_zone.label'), for: 'new_platform_platform_time_zone', class: 'form-label' %>
          <%= iana_time_zone_select(f, :time_zone, @platform&.time_zone,
            {},
            {
              class: 'form-select',
              id: 'new_platform_platform_time_zone',
              required: true,
              'aria-describedby': 'new_platform_platform_time_zone_help'
            }
          ) %>
          <small id="new_platform_platform_time_zone_help" class="form-text text-muted">
            <%= t('.fields.time_zone.help') %>
          </small>
        </div>

        <div class="mb-3">
          <%= f.submit t('.buttons.next'), id: 'new-platform-setup-platform-identity-submit-btn', class: 'btn btn-primary w-100' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
