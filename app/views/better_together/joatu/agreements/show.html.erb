<% content_for :page_title do %>
  <%= @joatu_agreement %> | <%= BetterTogether::Joatu::Agreement.model_name.human.pluralize %>
<% end %>

<%= render 'better_together/joatu/shared/exchange_nav' %>

<div class="container my-3">
  <%= render 'better_together/shared/help_banner',
             id: 'joatu-agreements-show',
             i18n_key: 'better_together.joatu.help.agreements.show' %>
  <div class="row">
    <div class="col-md-8">
      <h1 class="mb-3">
        <%= t('better_together.joatu.agreements.show.title', default: 'Agreement') %>
      </h1>

      <div class="alert alert-light border">
        This agreement records a mutual aid match between one offer and one request. Review the participants, what is being agreed to, and the next step before accepting or rejecting it.
      </div>

      <div class="panel panel-default mb-3">
        <div class="panel-heading">
          <h2 class="h5 mb-0">What is being agreed to</h2>
        </div>
        <div class="panel-body">
          <p class="mb-1"><strong><%= t('better_together.joatu.agreements.show.agreement_family', default: 'Agreement Family') %>:</strong>
            <%= @joatu_agreement.agreement_family.humanize %>
          </p>
          <p class="mb-1"><strong><%= t('better_together.joatu.agreements.show.agreement_type', default: 'Agreement Type') %>:</strong>
            <%= @joatu_agreement.agreement_type.humanize %>
          </p>
          <p class="mb-1"><strong><%= t('better_together.joatu.agreements.offer', default: 'Offer') %>:</strong>
            <%= link_to @joatu_agreement.offer.name, joatu_offer_path(@joatu_agreement.offer), class: 'text-decoration-none' %>
          </p>
          <p class="mb-1"><strong><%= t('better_together.joatu.agreements.request', default: 'Request') %>:</strong>
            <%= link_to @joatu_agreement.request.name, joatu_request_path(@joatu_agreement.request), class: 'text-decoration-none' %>
          </p>
          <p class="mb-0"><strong><%= t('better_together.joatu.agreements.status', default: 'Status') %>:</strong>
            <span class="badge <%= @joatu_agreement.status_accepted? ? 'bg-success' : (@joatu_agreement.status_rejected? ? 'bg-danger' : 'bg-secondary') %>">
              <%= @joatu_agreement.status %>
            </span>
          </p>
          <% if @joatu_agreement.decision_made_at.present? %>
            <p class="mb-0"><strong><%= t('better_together.joatu.agreements.show.decision_made_at', default: 'Decision Recorded') %>:</strong>
              <%= l(@joatu_agreement.decision_made_at, format: :long) %>
            </p>
          <% end %>

          <% if @joatu_agreement.connection_request? %>
            <hr>
            <p class="mb-1"><strong><%= t('better_together.joatu.agreements.show.source_platform') %>:</strong>
              <%= link_to @joatu_agreement.offer.target.name, @joatu_agreement.offer.target %>
            </p>
            <p class="mb-1"><strong><%= t('better_together.joatu.agreements.show.target_platform') %>:</strong>
              <%= link_to @joatu_agreement.request.target.name, @joatu_agreement.request.target %>
            </p>
            <% if @joatu_agreement.platform_connection.present? %>
              <p class="mb-0">
                <strong><%= t('better_together.joatu.agreements.show.platform_connection') %>:</strong>
                <%= link_to "#{@joatu_agreement.platform_connection.source_platform.name} → #{@joatu_agreement.platform_connection.target_platform.name}",
                            platform_connection_path(@joatu_agreement.platform_connection),
                            class: 'text-decoration-none' %>
              </p>
            <% elsif policy(BetterTogether::PlatformConnection).index? %>
              <p class="mb-0">
                <%= link_to t('better_together.joatu.agreements.show.open_platform_connections'), platform_connections_path, class: 'btn btn-sm btn-outline-primary' %>
              </p>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="panel panel-default mb-3">
        <div class="panel-heading">
          <h2 class="h5 mb-0">Terms and commitments</h2>
        </div>
        <div class="panel-body">
          <% if @joatu_agreement.terms.present? %>
            <%= @joatu_agreement.terms %>
          <% else %>
            <p class="text-muted mb-0">No additional terms were recorded for this mutual aid agreement.</p>
          <% end %>
        </div>
      </div>

      <div class="panel panel-default mb-3">
        <div class="panel-heading">
          <h2 class="h5 mb-0">What happens next</h2>
        </div>
        <div class="panel-body">
          <% if @joatu_agreement.status_pending? %>
            <p class="mb-0">If both sides are ready to proceed, accept the agreement to close the matched offer and request and move the support relationship forward. Rejecting the agreement keeps a decision record without closing the loop as successful.</p>
          <% elsif @joatu_agreement.status_accepted? %>
            <p class="mb-0">This mutual aid agreement has been accepted. The linked offer and request have been closed and should now be treated as an active support connection.</p>
          <% else %>
            <p class="mb-0">This mutual aid agreement was rejected. Use the related offer and request records to decide whether to revise terms, open a new match, or close the thread.</p>
          <% end %>
        </div>
      </div>

      <% unless @joatu_agreement.status_accepted? || @joatu_agreement.status_rejected? %>
        <div class="d-flex gap-2">
          <%= button_to t('better_together.joatu.agreements.accept', default: 'Accept'),
                        accept_joatu_agreement_path(@joatu_agreement),
                        method: :post,
                        class: 'btn btn-success', data: { turbo: false } %>
          <%= button_to t('better_together.joatu.agreements.reject', default: 'Reject'),
                        reject_joatu_agreement_path(@joatu_agreement),
                        method: :post,
                        class: 'btn btn-outline-danger', data: { turbo: false } %>
        </div>
      <% end %>

    </div>

    <div class="col-md-4">
      <div class="panel panel-info mb-3">
        <div class="panel-heading">
          <h2 class="h5 mb-0"><%= t('better_together.joatu.agreements.participants', default: 'Participants') %></h2>
        </div>
        <div class="panel-body">
          <p class="text-muted small">These are the people directly involved in this mutual aid agreement.</p>
          <% @joatu_agreement.participant_roles.each do |role, participant| %>
            <p class="<%= role == @joatu_agreement.participant_roles.keys.last ? 'mb-0' : 'mb-1' %>">
              <strong><%= t("better_together.joatu.agreements.#{role}", default: role.to_s.humanize) %>:</strong>
              <%= participant.name.presence || participant.to_s %>
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
 
