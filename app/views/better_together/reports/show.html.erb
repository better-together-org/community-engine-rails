<% content_for :page_title, t('better_together.reports.show.title') %>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><%= t('better_together.reports.show.title') %></h1>
    <%= link_to t('better_together.reports.show.back'),
                reports_path(locale: I18n.locale),
                class: 'btn btn-outline-secondary' %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body">
      <div class="row g-4">
        <div class="col-lg-8">
          <dl class="row mb-0">
            <dt class="col-sm-4"><%= t('better_together.reports.show.reported_record', default: 'Reported record') %></dt>
            <dd class="col-sm-8">
              <%= @report.reportable.class.model_name.human %>:
              <%= content_actions_resource_name(@report.reportable) %>
            </dd>

            <dt class="col-sm-4"><%= t('better_together.reports.attributes.category') %></dt>
            <dd class="col-sm-8"><%= safety_enum_label('report_categories', @report.category) %></dd>

            <dt class="col-sm-4"><%= t('better_together.reports.attributes.harm_level') %></dt>
            <dd class="col-sm-8"><%= safety_enum_label('harm_levels', @report.harm_level) %></dd>

            <dt class="col-sm-4"><%= t('better_together.reports.attributes.requested_outcome') %></dt>
            <dd class="col-sm-8"><%= safety_enum_label('requested_outcomes', @report.requested_outcome) %></dd>

            <dt class="col-sm-4"><%= t('better_together.reports.attributes.reason') %></dt>
            <dd class="col-sm-8"><%= simple_format(@report.reason) %></dd>

            <% if @report.private_details.present? %>
              <dt class="col-sm-4"><%= t('better_together.reports.attributes.private_details') %></dt>
              <dd class="col-sm-8"><%= simple_format(@report.private_details) %></dd>
            <% end %>
          </dl>
        </div>
        <div class="col-lg-4">
          <div class="border rounded p-3 bg-light">
            <div class="small text-muted mb-1"><%= t('better_together.reports.show.status') %></div>
            <div class="fw-semibold mb-3"><%= safety_enum_label('reporter_visible_statuses', @report.safety_case&.reporter_visible_status || 'submitted') %></div>

            <% if @report.safety_case&.closure_summary.present? %>
              <div class="small text-muted mb-1"><%= t('better_together.reports.show.summary') %></div>
              <div><%= simple_format(@report.safety_case.closure_summary) %></div>
            <% else %>
              <div class="small text-muted">
                <%= t('better_together.reports.show.pending_copy') %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mt-4">
    <div class="card-body">
      <h2 class="h5 mb-3">
        <%= t('better_together.reports.show.followup_title', default: 'More information or appeal') %>
      </h2>
      <p class="text-muted">
        <%= t(
              'better_together.reports.show.followup_help',
              default: 'Use this space to add authenticated follow-up evidence, context, or a request for another review without leaving your report history.'
            ) %>
      </p>

      <% if @participant_visible_notes.present? %>
        <div class="list-group mb-4">
          <% @participant_visible_notes.each do |note| %>
            <div class="list-group-item">
              <div class="small text-muted mb-1">
                <%= note.author.name %> · <%= l(note.created_at, format: :long) %>
              </div>
              <%= simple_format(note.body) %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="small text-muted">
          <%= t(
                'better_together.reports.show.followup_empty',
                default: 'No follow-up notes have been added to this report yet.'
              ) %>
        </p>
      <% end %>

      <% if policy(@report).add_followup? %>
        <%= form_with url: report_followup_path(@report, locale: I18n.locale), scope: :report_followup, local: true do |form| %>
          <div class="mb-3">
            <%= form.label :body,
                           t('better_together.reports.show.followup_label', default: 'Additional evidence or appeal note'),
                           class: 'form-label' %>
            <%= form.text_area :body,
                               rows: 5,
                               class: 'form-control',
                               aria: {
                                 describedby: 'report-followup-help'
                               } %>
            <p id="report-followup-help" class="form-text">
              <%= t(
                    'better_together.reports.show.followup_field_help',
                    default: 'Share any updated context, clarifications, or evidence you want a reviewer to consider.'
                  ) %>
            </p>
          </div>
          <%= form.submit t('better_together.reports.show.followup_submit', default: 'Add follow-up'),
                          class: 'btn btn-outline-danger' %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
