<turbo-frame id="agreement_modal_frame">
  <div class="container mt-4">
    <% if @page.present? %>
      <%= link_to 'Edit', edit_agreement_path(@agreement), class: 'btn btn-primary mt-3' if policy(@agreement).edit? %>
      <%= render template: 'better_together/pages/show' %>
    <% else %>
      <div class="card">
        <div class="card-header">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <h1 class="mb-0"><%= @agreement.title %></h1>
            <span class="badge <%= agreement_lifecycle_badge_class(@agreement) %>">
              <%= @agreement.lifecycle_display_name %>
            </span>
          </div>
        </div>
        <div class="card-body">
          <p class="card-text"><strong>Description:</strong> <%= @agreement.description %></p>
          <p class="card-text"><strong>Creator:</strong> <%= @agreement.creator %></p>
          <p class="card-text"><strong>Privacy:</strong> <%= privacy_display_value(@agreement) %></p>
          <p class="card-text"><strong>Required In Flow:</strong> <%= @agreement.required_for_display_name %></p>
          <% if @agreement.change_summary.present? %>
            <div class="alert alert-warning">
              <strong>Latest update:</strong> <%= @agreement.change_summary %>
            </div>
          <% end %>

            <hr>
            <h2 class="h5 mb-3"> <%= t('better_together.agreements.terms', default: 'Terms') %> </h2>
            <%= render partial: 'better_together/agreement_terms/terms_list', locals: { agreement: @agreement } %>
          <%= link_to 'Edit', edit_agreement_path(@agreement), class: 'btn btn-primary mt-3' if policy(@agreement).edit? %>
        </div>
      </div>
    <% end %>
  </div>
</turbo-frame>
