<%# app/views/better_together/membership_requests/show.html.erb %>

<div class="container py-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <%= link_to safe_join([tag.i('', class: 'fas fa-arrow-left', aria: { hidden: 'true' }),
                           ' ',
                           t('globals.back', default: 'Back')]),
                community_membership_requests_path(@community),
                class: 'btn btn-outline-secondary btn-sm' %>

    <span class="badge fs-6 bg-<%= membership_request_status_badge(@membership_request.status) %>">
      <%= @membership_request.status %>
    </span>
  </div>

  <div class="card">
    <div class="card-header">
      <h2 class="h5 mb-0">
        <%= t('better_together.membership_requests.show.title', default: 'Membership Request') %>
      </h2>
    </div>
    <div class="card-body">
      <dl class="row mb-0">
        <dt class="col-sm-3"><%= t('better_together.membership_requests.fields.requestor_name', default: 'Name') %></dt>
        <dd class="col-sm-9">
          <%= @membership_request.requestor_name.presence ||
              @membership_request.creator&.name ||
              t('globals.unknown', default: 'Unknown') %>
        </dd>

        <dt class="col-sm-3"><%= t('better_together.membership_requests.fields.requestor_email', default: 'Email') %></dt>
        <dd class="col-sm-9">
          <% email = @membership_request.requestor_email.presence || @membership_request.creator&.email %>
          <% if email %>
            <%= mail_to email %>
          <% else %>
            <span class="text-muted">—</span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= t('better_together.membership_requests.fields.target', default: 'Community') %></dt>
        <dd class="col-sm-9">
          <% if @membership_request.target.present? %>
            <%= link_to @membership_request.target.name, @membership_request.target %>
          <% else %>
            <span class="text-muted">—</span>
          <% end %>
        </dd>

        <dt class="col-sm-3"><%= t('better_together.membership_requests.fields.referral_source', default: 'Referral') %></dt>
        <dd class="col-sm-9"><%= @membership_request.referral_source.presence || '—' %></dd>

        <% if @membership_request.description.present? %>
          <dt class="col-sm-3"><%= t('better_together.membership_requests.fields.motivation', default: 'Motivation') %></dt>
          <dd class="col-sm-9"><%= @membership_request.description %></dd>
        <% end %>

        <dt class="col-sm-3"><%= t('globals.submitted_at', default: 'Submitted') %></dt>
        <dd class="col-sm-9"><%= l(@membership_request.created_at, format: :long) %></dd>
      </dl>
    </div>

    <% if @membership_request.status_open? %>
      <div class="card-footer d-flex gap-2">
        <% if policy(@membership_request).approve? %>
          <%= link_to t('better_together.membership_requests.actions.approve', default: 'Approve'),
                      approve_community_membership_request_path(@community, @membership_request),
                      data: { turbo_method: :post,
                              turbo_confirm: t('better_together.membership_requests.confirm_approve',
                                              default: 'Approve this membership request?') },
                      class: 'btn btn-success btn-sm' %>
        <% end %>

        <% if policy(@membership_request).decline? %>
          <%= link_to t('better_together.membership_requests.actions.decline', default: 'Decline'),
                      decline_community_membership_request_path(@community, @membership_request),
                      data: { turbo_method: :post,
                              turbo_confirm: t('better_together.membership_requests.confirm_decline',
                                              default: 'Decline this membership request?') },
                      class: 'btn btn-outline-warning btn-sm' %>
        <% end %>

        <% if policy(@membership_request).destroy? %>
          <%= link_to t('globals.delete', default: 'Delete'),
                      community_membership_request_path(@community, @membership_request),
                      data: { turbo_method: :delete,
                              turbo_confirm: t('better_together.membership_requests.confirm_delete',
                                              default: 'Remove this membership request?') },
                      class: 'btn btn-outline-danger btn-sm' %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
