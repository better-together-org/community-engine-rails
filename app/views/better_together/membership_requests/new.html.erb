<%# app/views/better_together/membership_requests/new.html.erb %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
  <div class="mb-4">
    <h1 class="h3">
      <%= t('better_together.membership_requests.new.heading', default: 'Request Membership') %>
      <span class="text-muted fw-normal">— <%= @community.name %></span>
    </h1>
    <p class="text-muted">
      <%= t('better_together.membership_requests.new.intro',
            default: "Fill in the form below to request membership. We'll be in touch!") %>
    </p>
  </div>

  <%= render 'form', membership_request: @membership_request, community: @community %>
    </div>
  </div>
</div>
