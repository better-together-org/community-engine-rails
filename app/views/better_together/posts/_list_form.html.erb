<%= form_with url: posts_path, method: :get, class: 'posts-filter-sidebar', local: true do |f| %>
  <fieldset>
    <legend><%= t('.filters') %></legend>

    <!-- Text Search -->
    <div class="form-group">
      <%= f.label :q, t('.search_label') %>
      <%= f.text_field :q, placeholder: t('.search_placeholder'), value: params[:q] %>
    </div>

    <!-- Categories -->
    <% if @categories&.any? %>
      <div class="form-group">
        <%= f.label :category_ids, t('.categories_label') %>
        <div class="checkboxes">
          <% @categories.each do |category| %>
            <div class="checkbox">
              <%= f.check_box :category_ids, { multiple: true, include_hidden: false }, category.id %>
              <%= f.label :"category_ids_#{category.id}", category.name %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Privacy Filter -->
    <div class="form-group">
      <%= f.label :privacy, t('.privacy_label') %>
      <%= f.select :privacy, options_for_select([
        [t('.privacy_all'), ''],
        [t('.privacy_public'), 'public'],
        [t('.privacy_community'), 'community'],
        [t('.privacy_private'), 'private']
      ], params[:privacy]), { include_blank: false } %>
    </div>

    <!-- Order By -->
    <div class="form-group">
      <%= f.label :order_by, t('.order_by_label') %>
      <%= f.select :order_by, options_for_select([
        [t('.order_newest'), ''],
        [t('.order_oldest'), 'oldest']
      ], params[:order_by]), { include_blank: false } %>
    </div>

    <!-- Per Page -->
    <div class="form-group">
      <%= f.label :per_page, t('.per_page_label') %>
      <%= f.select :per_page, options_for_select(['10', '20', '50'], params[:per_page] || '20') %>
    </div>

    <!-- Submit & Clear -->
    <div class="form-actions">
      <%= f.submit t('.search_button'), class: 'btn btn-primary' %>
      <%= link_to t('.clear_filters'), posts_path, class: 'btn btn-secondary' %>
    </div>
  </fieldset>
<% end %>
