<% content_for :page_title do %>
  <%= resource_class.model_name.human.pluralize %>
<% end %>

<div class="container my-3">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="mb-0"><%= resource_class.model_name.human.pluralize %></h1>
    <% if policy(resource_class.new).create? %>
      <%= link_to new_event_path, class: 'btn btn-success', id: 'new-event-btn',
                  'aria-label' => t('.new_btn_text') do %>
        <i class="fas fa-plus"></i> <%= t('.new_btn_text') %>
      <% end %>
    <% end %>
  </div>
  <% if policy(resource_class.new).create? %>
    <%= render 'better_together/shared/publishing_agreement_notice' %>
  <% end %>

  <div class="row">
    <!-- Filter Sidebar -->
    <div class="col-lg-3 mb-4">
      <button class="btn btn-outline-secondary d-lg-none mb-2 sidebar-toggle" type="button"
              data-bs-toggle="collapse" data-bs-target="#events-filter-sidebar"
              aria-expanded="false" aria-controls="events-filter-sidebar">
        <i class="fas fa-filter" aria-hidden="true"></i> <%= t('.toggle_filters') %>
      </button>
      <div id="events-filter-sidebar" class="collapse d-lg-block sidebar">
        <%= render 'list_form' %>
      </div>
    </div>

    <!-- Events List -->
    <div class="col-lg-9">

      <!-- Pagination -->
      <% if @events.respond_to?(:total_pages) && @events.total_pages > 1 %>
        <nav class="d-flex justify-content-center">
          <%= paginate @events %>
        </nav>
      <% end %>

      <!-- Result Count -->
      <% if @events.any? && @events.respond_to?(:total_count) %>
        <div class="mb-3">
          <small class="text-muted">
            <%= t('.result_count', count: @events.total_count) %>
          </small>
        </div>
      <% end %>

      <% if @events.any? %>
        <div id="events" class="row row-cols-1 row-cols-md-2">
          <%= render @events %>
        </div>
      <% else %>
        <%= render 'none' %>
      <% end %>

      <!-- Pagination -->
      <% if @events.respond_to?(:total_pages) && @events.total_pages > 1 %>
        <nav class="d-flex justify-content-center">
          <%= paginate @events %>
        </nav>
      <% end %>
    </div>
  </div>
</div>
