<%# locals: (form: ) %>
<div class="nested-fields agreement-term my-3" data-new-record="<%= form.object.new_record? %>">
  <div class="row mt-3">
    <div class="col-12 col-xl-3 my-3">
      <%= form.label :position, 'Clause Order', class: 'form-label' %>
      <%= form.number_field :position, class: 'form-control', min: 0, step: 1 %>
    </div>
    <div class="col-12 col-xl-9 my-3">
      <%= render partial: 'better_together/shared/translated_string_field', locals: { model: form.object, form: form, attribute: 'summary' } %>
    </div>
    <div class="col-12 col-xl-6 my-3">
      <%= render partial: 'better_together/shared/translated_rich_text_field', locals: { model: form.object, form: form, attribute: 'content' } %>
    </div>
  </div>
</div>
