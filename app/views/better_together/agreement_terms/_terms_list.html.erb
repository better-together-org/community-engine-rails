<%# Renders the agreement's terms in a simple list format %>
<% if agreement.agreement_terms.any? %>
  <ul class="list-group">
    <% agreement.agreement_terms.each_with_index do |term, index| %>
      <li class="list-group-item">
        <div class="text-muted small mb-1">Clause <%= term.position.presence || index + 1 %></div>
        <% if term.summary.present? %>
          <h6><%= term.summary %></h6>
        <% end %>
        <% if term.content.to_plain_text.present? %>
          <%= term.content %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-muted"><%= t('better_together.agreements.no_terms', default: 'No terms defined.') %></p>
<% end %>
