<%# Custom (not generic_notification) so the commenter renders via the shared
    people/mention partial (avatar + linked name), and so the title links to
    comment_url — the notifier's actual url method, which generic_notification's
    event.respond_to?(:url) check never finds (CommentAddedNotifier defines
    comment_url, not url), leaving this notification's title unlinked before. %>
<% event = notification.event %>
<% notification_title = event.respond_to?(:title) ? event.title : notification.try(:title) %>
<% notification_url = event.respond_to?(:comment_url) ? event.comment_url : nil %>

<%= render layout: 'better_together/notifications/notification',
           locals: { notification:, notification_title:, notification_url: } do %>
  <% cache ['comment_added_notification_content', notification.cache_key_with_version, I18n.locale] do %>
    <% if notification.comment&.creator.present? %>
      <%= render partial: 'better_together/people/mention',
                 locals: { person: notification.comment.creator, flex_layout: 'flex-row', flex_align_items: 'left',
                           justify_content: 'start' } %>
    <% end %>
    <p class="mb-1"><%= event.respond_to?(:body) ? event.body : notification.try(:body) %></p>
  <% end %>
<% end %>
