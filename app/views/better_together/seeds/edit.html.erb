<% content_for :page_title do %>
  <%= t('seeds.edit.title', identifier: @seed.identifier) %> | <%= t('seeds.index.title') %>
<% end %>

<div class="container my-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1><%= t('seeds.edit.title', identifier: @seed.identifier) %></h1>
    <div class="d-flex gap-2">
      <% if policy(@seed).show? %>
        <%= link_to seed_path(@seed), class: 'btn btn-outline-info' do %>
          <i class="fas fa-eye" aria-hidden="true"></i> <%= t('globals.show') %>
        <% end %>
      <% end %>
      <%= link_to seeds_path, class: 'btn btn-outline-secondary' do %>
        <i class="fas fa-arrow-left" aria-hidden="true"></i> <%= t('globals.back_to_list') %>
      <% end %>
    </div>
  </div>

  <div id="form_errors"></div>
  <%= render 'form', seed: @seed %>
</div>
