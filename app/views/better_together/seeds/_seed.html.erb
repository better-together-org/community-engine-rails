<div id="<%= dom_id seed %>" class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h5 class="card-title mb-1">
          <%= seed.identifier %>
          <span class="badge bg-secondary ms-1"><%= seed.version %></span>
          <span class="badge bg-info ms-1"><%= seed.type.demodulize %></span>
        </h5>
        <p class="card-text text-muted mb-1"><%= seed.description %></p>
        <small class="text-muted">
          <%= t('seeds.seeded_by', created_by: seed.created_by) %> &middot;
          <%= l(seed.seeded_at, format: :short) if seed.seeded_at %>
        </small>
      </div>
      <div class="d-flex gap-1">
        <% if policy(seed).show? %>
          <%= link_to seed_path(seed), class: 'btn btn-outline-secondary btn-sm',
                      'aria-label' => t('seeds.actions.show') do %>
            <i class="fas fa-eye" aria-hidden="true"></i>
          <% end %>
        <% end %>
        <% if policy(seed).update? %>
          <%= link_to edit_seed_path(seed), class: 'btn btn-outline-secondary btn-sm',
                      'aria-label' => t('seeds.actions.edit') do %>
            <i class="fas fa-edit" aria-hidden="true"></i>
          <% end %>
        <% end %>
        <% if policy(seed).destroy? %>
          <%= link_to seed_path(seed),
                      data: { 'turbo-method': 'delete', turbo_confirm: t('seeds.confirm_destroy') },
                      class: 'btn btn-outline-danger btn-sm',
                      'aria-label' => t('seeds.actions.destroy') do %>
            <i class="fas fa-trash-alt" aria-hidden="true"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
