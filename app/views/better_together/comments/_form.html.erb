<%# locals: (commentable:, comment: BetterTogether::Comment.new) %>
<div id="new_comment">
  <%= form_with model: comment, url: comments_path, local: false do |form| %>
    <%# Top-level (not comment[...]-namespaced) so the controller can resolve the
        commentable the same way ReportsController resolves reportable_type/reportable_id. %>
    <%= hidden_field_tag :commentable_type, commentable.class.base_class.name %>
    <%= hidden_field_tag :commentable_id, commentable.id %>

    <% if comment.errors.any? %>
      <div class="alert alert-danger py-2 px-3 mb-2" role="alert" aria-labelledby="comment-errors-title">
        <span id="comment-errors-title" class="visually-hidden">
          <%= t('better_together.comments.form.error_summary', default: 'This comment could not be posted') %>
        </span>
        <ul class="mb-0 ps-3">
          <% comment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-2">
      <%# Explicit id/for: this app's form_with config doesn't auto-generate field ids. %>
      <%= form.label :content, t('better_together.comments.form.label', default: 'Add a comment'),
                      for: 'comment_content', class: 'visually-hidden' %>
      <%= form.text_area :content, id: 'comment_content',
                          class: "form-control#{' is-invalid' if comment.errors[:content].present?}", rows: 2,
                          required: true,
                          placeholder: t('better_together.comments.form.placeholder', default: 'Write a comment…') %>
    </div>

    <%= form.submit t('better_together.comments.form.submit', default: 'Post comment'), class: 'btn btn-primary btn-sm' %>
  <% end %>
</div>
