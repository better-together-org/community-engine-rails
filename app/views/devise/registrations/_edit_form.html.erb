<%= turbo_frame_tag "account-settings" do %>
  <div class="container mt-0">
    <div class="row">
      <div class="col-12">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name, format: :turbo_stream), html: { method: :put, class: 'needs-validation', novalidate: true, data: { turbo_frame: "account-settings", controller: "better_together--form-validation" } }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>
          <div id="form_errors"></div>
          <!-- Email Field -->
          <div class="mb-3">
            <%= f.label :email, class: 'form-label' %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form-control' %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="alert alert-info">
              <%= t('devise.registrations.edit.currently_waiting_confirmation_for_email', email: resource.unconfirmed_email) %>
            </div>
          <% end %>

          <% if resource.oauth_without_password? %>
            <div class="alert alert-info">
              <%= t('devise.registrations.edit.oauth_user_set_password_info') %>
            </div>
          <% end %>

          <!-- Password Field -->
          <div class="mb-3">
            <%= f.label :password, class: 'form-label' %>
            <% if resource.oauth_without_password? %>
              <i>(<%= t('devise.registrations.edit.set_password_to_enable_email_login') %>)</i>
            <% else %>
              <i>(<%= t('devise.registrations.edit.leave_blank_if_you_don_t_want_to_change_it') %>)</i>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: 'form-control' %>
            <% if @minimum_password_length %>
              <small class="form-text text-muted">
                <%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %>
              </small>
            <% end %>
          </div>

          <!-- Password Confirmation Field -->
          <div class="mb-3">
            <%= f.label :password_confirmation, class: 'form-label' %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form-control' %>
          </div>

          <!-- Current Password Field -->
          <% unless resource.oauth_without_password? %>
            <div class="mb-3">
              <%= required_label f, :current_password, class: 'form-label' %>
              <i>(<%= t('devise.registrations.edit.we_need_your_current_password_to_confirm_your_changes') %>)</i>
              <%= f.password_field :current_password, autocomplete: "current-password", class: 'form-control', required: true %>
            </div>
          <% end %>

          <!-- Update Button -->
          <div class="text-center mb-4">
            <%= f.submit t('devise.registrations.edit.update'), class: 'btn btn-primary' %>
          </div>
        <% end %>

        <hr class="my-4">

        <section aria-labelledby="account-deletion-title">
          <h3 id="account-deletion-title" class="h5 mb-1"><%= t('better_together.settings.index.my_data.deletion.title') %></h3>
          <p class="text-muted"><%= t('better_together.settings.index.my_data.deletion.description') %></p>

          <%= form_with url: person_deletion_requests_path(locale: I18n.locale), method: :post, local: true do |deletion_form| %>
            <div class="mb-3">
              <%= deletion_form.label :requested_reason, t('better_together.settings.index.my_data.deletion.reason'), class: 'form-label' %>
              <%= deletion_form.text_area :requested_reason,
                                          name: 'person_deletion_request[requested_reason]',
                                          rows: 3,
                                          class: 'form-control' %>
            </div>
            <%= deletion_form.submit t('better_together.settings.index.my_data.deletion.submit'), class: 'btn btn-outline-danger' %>
          <% end %>

          <% if @person_deletion_requests&.any? %>
            <hr>
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th><%= t('better_together.settings.index.my_data.deletion.requested_at') %></th>
                    <th><%= t('better_together.settings.index.my_data.deletion.status') %></th>
                    <th><%= t('better_together.settings.index.my_data.deletion.actions') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% @person_deletion_requests.each do |request| %>
                    <tr id="person_deletion_request_<%= request.id %>">
                      <td><%= l(request.requested_at, format: :long) %></td>
                      <td><span class="badge text-bg-warning"><%= request.status.humanize %></span></td>
                      <td>
                        <% if request.pending? %>
                          <%= button_to t('better_together.settings.index.my_data.deletion.cancel'),
                                        person_deletion_request_path(request, locale: I18n.locale),
                                        method: :delete,
                                        class: 'btn btn-sm btn-outline-secondary' %>
                        <% else %>
                          <span class="text-muted small"><%= request.resolved_at ? l(request.resolved_at, format: :long) : '—' %></span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </section>
      </div>
    </div>
  </div>
<% end %>
