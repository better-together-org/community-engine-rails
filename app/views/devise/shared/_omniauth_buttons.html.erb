<% devise_mapping = local_assigns.key?(:devise_mapping) ? local_assigns[:devise_mapping] : devise_mapping %>
<% resource_class = local_assigns.key?(:resource_class) ? local_assigns[:resource_class] : resource_class %>
<% resource_name = local_assigns.key?(:resource_name) ? local_assigns[:resource_name] : resource_name %>
<%- if devise_mapping.omniauthable? %>
  <% available_providers = configured_omniauth_providers(resource_class) %>
  <% if available_providers.any? %>
  <div class="mt-3">
    <div class="d-flex gap-2 flex-wrap justify-content-center">
      <%- available_providers.each do |provider| %>
        <%= button_to omniauth_authorize_path(resource_name, provider),
                      method: :post,
                      class: oauth_provider_button_class(provider),
                      data: { turbo: false },
                      form: { data: { turbo: false } } do %>
          <i class="<%= oauth_provider_icon_class(provider) %> me-2" aria-hidden="true"></i>
          <%= t('devise.shared.links.sign_in_with_provider', provider: OmniAuth::Utils.camelize(provider)) %>
        <% end %>
      <% end %>
    </div>
  </div>
  <% end %>
<% end %>
