
<% if object.errors.any? %>
  <div id="form_errors" class="alert alert-danger" role="alert">
    <h4 class="alert-heading">The following errors occurred:</h4>
    <ul>
      <% object.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
    <% if missing_publishing_agreement_error_for?(object) %>
      <div class="mt-3">
        <%= link_to 'Review and accept the content publishing agreement',
                    better_together.agreements_status_path(
                      locale: I18n.locale,
                      agreement: BetterTogether::PublicVisibilityGate::AGREEMENT_IDENTIFIER,
                      return_to: request.fullpath
                    ),
                    class: 'btn btn-sm btn-outline-danger' %>
      </div>
    <% end %>
  </div>
<% end %>
