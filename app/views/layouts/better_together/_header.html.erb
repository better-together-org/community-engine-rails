<!-- Navbar -->
<div id="main-nav" class="container-fluid shadow-sm" data-controller="better_together--nav-height">
  <nav id="top-nav" class="navbar navbar-expand-lg navbar-dark pb-0 justify-content-center">
    <%= render 'layouts/better_together/navbar_brand' %>

    <ul id="primary-nav" class="navbar-nav text-center ms-auto flex-row align-items-center gap-2 gap-md-3">
      <!-- Social Media Accounts (visible on large screens) -->
      <div id="social-media-icons">
        <% cache nav_fragment_cache_key('header_social_media') do %>
          <%= render_host_community_social_media_accounts %>
        <% end %>
      </div>

      <%= yield :editor_status if content_for? :editor_status %>

      <%= render 'layouts/better_together/search' %>
      <%= render 'layouts/better_together/notifications' if user_signed_in? %>
      <%= render 'layouts/better_together/locale_switcher' %>

      <% if user_signed_in? %>
        <!-- User Auth Nav Item -->
        <% cache_key = nav_fragment_cache_key('user_nav', nav_areas: [platform_host_nav_area]) %>
        <%= cache cache_key do %>
          <%= render 'layouts/better_together/user_nav' %>
        <% end %>
      <% else %>
        <%= render 'layouts/better_together/sign_in' %>
      <% end %>
    </ul>

    <% if platform_header_nav_area %>
      <!-- Toggler for mobile view -->
      <button class="navbar-toggler ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#headerNav" aria-controls="headerNav" aria-expanded="false" aria-label="<%= t('navbar.toggle_navigation') %>">
        <span class="navbar-toggler-icon"></span>
      </button>
    <% end %>
  </nav>

  <nav id="header-nav" class="navbar navbar-expand-lg navbar-dark pt-0 bt-underline-nav">
    <div class="collapse justify-content-center navbar-collapse align-content-center" id="headerNav">
      <!-- Right-aligned nav items -->
      <%= cache nav_fragment_cache_key('platform_header_nav', nav_areas: [platform_header_nav_area]) do %>
        <%= render_platform_header_nav_items %>
      <% end %>
    </div>
  </nav>

  <!-- Hidden Search Form below navbar -->
  <div class="collapse <%= 'show w-100 position-static' if current_page?(search_path) %>" id="navbarSearch" data-controller="better_together--search-focus">
    <div class="container my-3">
      <%= render 'better_together/shared/search_bar' %>
    </div>
  </div>

</div>
