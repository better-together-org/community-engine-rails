%% render.orientation: landscape
flowchart LR
  smtp["Public mail router / MX entrypoint"]
  relay["CE /inbound-email/relay\nHTTP basic auth + message/rfc822"]
  action_mailbox["Action Mailbox inbound email"]
  ce_mailbox["BetterTogether::ApplicationMailbox"]
  app_mailbox["Host app ApplicationMailbox"]
  router_mailbox["BetterTogether::RouterMailbox"]
  routing["InboundEmailRoutingService"]
  domain["PlatformDomain.resolve(recipient domain)"]
  audit["InboundEmailMessage\n(platform + route + status + sender + recipient + message-id)"]
  request["MembershipRequest"]
  community["Community target"]
  agent["Tenant robot / tenant person target"]
  reject["Rejected / unresolved record"]

  smtp --> relay --> action_mailbox --> ce_mailbox --> app_mailbox --> router_mailbox --> routing
  routing --> domain
  domain -->|"tenant matched"| audit
  domain -->|"unknown domain"| reject
  audit -->|"requests+community-slug"| request
  audit -->|"community+community-slug"| community
  audit -->|"agent+identifier"| agent
  audit -->|"cross-tenant or unknown alias"| reject
