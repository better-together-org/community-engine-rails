#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

# shellcheck source=./docker-compose-env.sh
source "$repo_root/bin/docker-compose-env.sh"

if [[ -z "${CE_WORKTREE_DB_SUFFIX:-}" ]]; then
  exit 0
fi

primary_test_db="community_engine_test${CE_WORKTREE_DB_SUFFIX}"

sync_schema_migrations_versions() {
  local database_name="$1"
  while IFS= read -r version; do
    docker exec community-engine-db psql -U postgres -d "$database_name" -v ON_ERROR_STOP=1 \
      -c "INSERT INTO schema_migrations (version) VALUES ('$version') ON CONFLICT DO NOTHING;" >/dev/null
  done < <(
    find "$repo_root/db/migrate" -maxdepth 1 -type f -name '*.rb' -printf '%f\n' \
      | sed -E 's/_.*$//' \
      | sort -u
  )
}

if docker exec community-engine-db psql -U postgres -tAc \
  "SELECT 1 FROM pg_database WHERE datname='${primary_test_db}'" | grep -q 1; then
  while IFS= read -r existing_db; do
    sync_schema_migrations_versions "$existing_db"
  done < <(
    docker exec community-engine-db psql -U postgres -tA -c \
      "SELECT datname FROM pg_database WHERE datname LIKE '${primary_test_db}%';"
  )
  exit 0
fi

echo "Preparing worktree test databases for suffix ${CE_WORKTREE_DB_SUFFIX}..."

# Rebuild the primary test DB from schema in the dummy app context.
./bin/dc run --rm --no-deps app env RAILS_ENV=test ./bin/dummy rails db:drop db:create db:schema:load >/dev/null
sync_schema_migrations_versions "$primary_test_db"

# Prepare the parallel test DBs for prspec-style runs in the same worktree.
./bin/dc run --rm --no-deps app env RAILS_ENV=test ./bin/dummy bundle exec rake \
  db:parallel:purge db:parallel:create db:parallel:prepare >/dev/null

while IFS= read -r parallel_db; do
  sync_schema_migrations_versions "$parallel_db"
done < <(
  docker exec community-engine-db psql -U postgres -tA -c \
    "SELECT datname FROM pg_database WHERE datname LIKE '${primary_test_db}%';"
)
