#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

# shellcheck source=./docker-compose-env.sh
source "$repo_root/bin/docker-compose-env.sh"

compose_files=("-f" "docker-compose.yml")

# Local dev convenience: if a developer has a .env file, layer in
# docker-compose.dev.yml which opts services into loading it.
if [[ -f ".env" && -f "docker-compose.dev.yml" ]]; then
	compose_files+=("-f" "docker-compose.dev.yml")
fi

# Auto-activate the stripe profile when STRIPE_PRIVATE_KEY is set and non-empty.
# This starts the stripe-cli webhook-forwarding container without any manual flags.
stripe_profile_flag=()
stripe_key="${STRIPE_PRIVATE_KEY:-}"
if [[ -z "$stripe_key" && -f ".env.dev" ]]; then
  stripe_key="$(grep -E '^STRIPE_PRIVATE_KEY=.' .env.dev | cut -d= -f2- | tr -d "'\"" | head -1)"
fi
if [[ -n "$stripe_key" ]]; then
  stripe_profile_flag=("--profile" "stripe")

  # Auto-populate STRIPE_SIGNING_SECRET in .env.dev when it is blank.
  # Uses a one-shot stripe-cli container with --print-secret so the app always
  # has the correct whsec_ value without any manual copy-paste step.
  if [[ -f ".env.dev" ]]; then
    current_signing_secret="$(grep -E '^STRIPE_SIGNING_SECRET=.' .env.dev | cut -d= -f2- | tr -d "'\"" | head -1)"
    if [[ -z "$current_signing_secret" ]]; then
      echo "[bin/dc] Fetching Stripe webhook signing secret via stripe-cli..." >&2
      fetched_secret="$(docker run --rm stripe/stripe-cli:latest listen \
        --api-key "$stripe_key" --print-secret 2>/dev/null || true)"
      if [[ "$fetched_secret" == whsec_* ]]; then
        sed -i "s|^STRIPE_SIGNING_SECRET=.*|STRIPE_SIGNING_SECRET=${fetched_secret}|" .env.dev
        echo "[bin/dc] STRIPE_SIGNING_SECRET written to .env.dev" >&2
      else
        echo "[bin/dc] Warning: could not fetch Stripe signing secret (check STRIPE_PRIVATE_KEY)" >&2
      fi
    fi
  fi
fi

USER="$(id -u)" docker compose "${compose_files[@]}" "${stripe_profile_flag[@]}" "$@"
